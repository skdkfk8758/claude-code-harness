{
    "version": "1.0",
    "description": "Skill activation triggers for CCH workflow. Controls when skills automatically suggest or block actions.",
    "skills": {
        "workflow": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Workflow orchestrator for multi-step development pipelines",
            "promptTriggers": {
                "keywords": [
                    "workflow",
                    "워크플로우",
                    "파이프라인",
                    "pipeline",
                    "feature development",
                    "기능 개발",
                    "start project",
                    "프로젝트 시작",
                    "planning-only",
                    "플래닝"
                ],
                "intentPatterns": [
                    "(start|begin|시작).*?(feature|기능|project|프로젝트|workflow|워크플로우)",
                    "(which|어떤).*?(workflow|워크플로우)",
                    "(resume|재개|이어).*?(workflow|워크플로우|작업)"
                ]
            }
        },
        "brainstorming": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Design gate — must be used before any creative or feature work",
            "promptTriggers": {
                "keywords": [
                    "design",
                    "설계",
                    "brainstorm",
                    "브레인스토밍",
                    "feature",
                    "기능",
                    "new feature",
                    "새 기능",
                    "architecture",
                    "아키텍처",
                    "approach",
                    "접근법",
                    "option",
                    "옵션"
                ],
                "intentPatterns": [
                    "(create|add|build|implement|만들|추가|구현).*?(feature|기능|component|컴포넌트)",
                    "(design|설계|plan|계획).*?(approach|접근|option|옵션)",
                    "(how should|어떻게).*?(implement|구현|design|설계|build|만들)",
                    "(compare|비교).*?(option|옵션|approach|접근)"
                ]
            }
        },
        "writing-plans": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Task decomposition gate — break plans into executable tasks",
            "promptTriggers": {
                "keywords": [
                    "task breakdown",
                    "태스크 분해",
                    "task list",
                    "작업 목록",
                    "decompose",
                    "분해",
                    "implementation plan",
                    "구현 계획",
                    "write plan",
                    "플랜 작성"
                ],
                "intentPatterns": [
                    "(break|split|decompose|분해|쪼개).*?(task|작업|plan|플랜)",
                    "(create|write|작성).*?(task|작업).*?(list|목록|plan|플랜)",
                    "(plan|플랜).*?(execution|실행|implementation|구현)"
                ]
            }
        },
        "finishing-branch": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Completion gate — verify and integrate finished work",
            "promptTriggers": {
                "keywords": [
                    "done",
                    "완료",
                    "finish",
                    "마무리",
                    "merge",
                    "머지",
                    "PR",
                    "pull request",
                    "ship",
                    "배포"
                ],
                "intentPatterns": [
                    "(finish|complete|done|완료|마무리).*?(branch|브랜치|feature|기능|work|작업)",
                    "(create|make|만들).*?(PR|pull request)",
                    "(merge|머지).*?(branch|브랜치|main)"
                ]
            }
        },
        "tdd": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "high",
            "description": "TDD enforcement — no production code without failing test first",
            "promptTriggers": {
                "keywords": [
                    "implement",
                    "구현",
                    "code",
                    "코드",
                    "write code",
                    "코드 작성",
                    "function",
                    "함수",
                    "class",
                    "클래스"
                ],
                "intentPatterns": [
                    "(write|create|implement|작성|구현|만들).*?(code|코드|function|함수|class|클래스|method|메서드)",
                    "(add|추가).*?(feature|기능|endpoint|API)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src/**/*.ts",
                    "src/**/*.tsx",
                    "src/**/*.js",
                    "lib/**/*.ts",
                    "app/**/*.ts"
                ],
                "pathExclusions": [
                    "**/*.test.*",
                    "**/*.spec.*",
                    "**/test/**",
                    "**/tests/**"
                ]
            }
        },
        "systematic-debugging": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "critical",
            "description": "Debugging gate — root cause investigation before any fix",
            "promptTriggers": {
                "keywords": [
                    "bug",
                    "버그",
                    "error",
                    "에러",
                    "fail",
                    "실패",
                    "broken",
                    "깨진",
                    "crash",
                    "크래시",
                    "not working",
                    "안됨",
                    "안 돼",
                    "doesn't work"
                ],
                "intentPatterns": [
                    "(fix|수정|고치|debug|디버그).*?(bug|버그|error|에러|issue|이슈)",
                    "(test|테스트).*?(fail|실패|broken|깨진)",
                    "(why|왜).*?(not working|안 돼|fail|실패|error|에러)",
                    "something.*?(wrong|broke|broken)"
                ]
            }
        },
        "verification": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "critical",
            "description": "Verification gate — run commands before claiming success",
            "promptTriggers": {
                "keywords": [
                    "done",
                    "완료",
                    "fixed",
                    "수정됨",
                    "works",
                    "작동",
                    "passing",
                    "통과",
                    "ready",
                    "준비",
                    "commit",
                    "커밋"
                ],
                "intentPatterns": [
                    "(it|this).*?(works|passes|is fixed|is done)",
                    "(ready to|준비).*?(commit|커밋|merge|머지|PR|ship)",
                    "(all|모든).*?(tests|테스트).*?(pass|통과)"
                ]
            }
        },
        "skill-manager": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Skill and agent CRUD — add, remove, edit, validate skills and agents",
            "promptTriggers": {
                "keywords": [
                    "add skill",
                    "스킬 추가",
                    "create skill",
                    "스킬 생성",
                    "delete skill",
                    "스킬 삭제",
                    "edit skill",
                    "스킬 수정",
                    "manage skill",
                    "스킬 관리",
                    "add agent",
                    "에이전트 추가",
                    "create agent",
                    "에이전트 생성",
                    "delete agent",
                    "에이전트 삭제",
                    "validate skill",
                    "스킬 검증",
                    "dependency",
                    "의존성"
                ],
                "intentPatterns": [
                    "(add|create|make|추가|생성|만들).*?(skill|스킬|agent|에이전트)",
                    "(delete|remove|삭제|제거).*?(skill|스킬|agent|에이전트)",
                    "(edit|modify|update|수정|변경).*?(skill|스킬|agent|에이전트)",
                    "(list|show|목록|보여).*?(skill|스킬|agent|에이전트)",
                    "(validate|check|검증|확인).*?(skill|스킬|agent|에이전트)",
                    "(dependency|deps|의존성|참조).*?(analysis|분석|map|맵)"
                ]
            }
        },
        "workflow-manager": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Workflow CRUD — add, remove, edit, validate workflow definitions",
            "promptTriggers": {
                "keywords": [
                    "add workflow",
                    "워크플로우 추가",
                    "create workflow",
                    "워크플로우 생성",
                    "delete workflow",
                    "워크플로우 삭제",
                    "edit workflow",
                    "워크플로우 수정",
                    "manage workflow",
                    "워크플로우 관리",
                    "validate workflow",
                    "워크플로우 검증",
                    "list workflow",
                    "워크플로우 목록"
                ],
                "intentPatterns": [
                    "(add|create|make|추가|생성|만들).*?(workflow|워크플로우)",
                    "(delete|remove|삭제|제거).*?(workflow|워크플로우)",
                    "(edit|modify|update|수정|변경).*?(workflow|워크플로우)",
                    "(list|show|목록|보여).*?(workflow|워크플로우)",
                    "(validate|check|검증|확인).*?(workflow|워크플로우)"
                ]
            }
        },
        "error-learning": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Error learning loop — extract lessons from mistakes, check past patterns before coding",
            "promptTriggers": {
                "keywords": [
                    "lesson",
                    "교훈",
                    "mistake",
                    "실수",
                    "error pattern",
                    "에러 패턴",
                    "같은 실수",
                    "반복",
                    "repeat",
                    "learn",
                    "학습",
                    "past error",
                    "이전 에러"
                ],
                "intentPatterns": [
                    "(record|기록|저장).*?(mistake|실수|error|에러|lesson|교훈)",
                    "(같은|same|반복|repeat).*?(실수|mistake|error|에러|bug|버그)",
                    "(배우|learn|교훈|lesson).*?(실수|mistake|error|에러)",
                    "(check|확인|검색).*?(past|이전|과거).*?(error|에러|pattern|패턴)"
                ]
            }
        },
        "frontend-perf": {
            "type": "guardrail",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Frontend performance anti-pattern detection for changed files",
            "fileTriggers": {
                "pathPatterns": [
                    "**/*.tsx",
                    "**/*.jsx",
                    "**/components/**",
                    "**/pages/**",
                    "**/app/**",
                    "**/*.css",
                    "**/*.scss"
                ],
                "pathExclusions": [
                    "**/*.test.*",
                    "**/*.spec.*",
                    "**/node_modules/**"
                ]
            }
        },
        "plan-viewer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Project progress dashboard — view plans, tasks, workflow state, and next actions",
            "promptTriggers": {
                "keywords": [
                    "진행 상황",
                    "progress",
                    "현황",
                    "status",
                    "남은 작업",
                    "remaining",
                    "할 일",
                    "todo",
                    "다음 작업",
                    "next task",
                    "plan",
                    "플랜",
                    "태스크",
                    "task list",
                    "대시보드",
                    "dashboard"
                ],
                "intentPatterns": [
                    "(보여|show|확인|check).*?(진행|progress|상황|status|현황)",
                    "(남은|remaining|할|todo).*?(작업|task|일|work)",
                    "(다음|next).*?(작업|task|할 일|step)",
                    "(어디|where).*?(까지|진행|했|done)",
                    "(뭐|what).*?(남았|left|해야|should|할)"
                ]
            }
        },
        "setup": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Plugin environment setup — HUD deploy, health check, v2 cleanup",
            "promptTriggers": {
                "keywords": [
                    "setup",
                    "설정",
                    "초기화",
                    "install",
                    "설치",
                    "initialize",
                    "환경설정"
                ],
                "intentPatterns": [
                    "(setup|설정|초기화|설치).*?(cch|plugin|플러그인|harness|환경)",
                    "(install|설치).*?(hud|환경|plugin|플러그인)",
                    "(first|처음).*?(time|사용|setup|설정)"
                ]
            }
        }
    },
    "naturalLanguageResolution": {
        "description": "모든 user-invocable 스킬에 적용되는 자연어 입력 해석 프로토콜",
        "protocol": [
            "1. 정확한 명령/인자 매칭 시도 (exact match) → 즉시 실행",
            "2. 매칭 실패 → 자연어 키워드/의도 분석 → 가장 높은 매칭 서브커맨드로 라우팅",
            "3. 매칭 불가 → 사용자에게 의도 확인 (available commands 표시)",
            "4. 서브커맨드 없는 스킬 (자유 컨텍스트형) → 입력 전체를 컨텍스트로 사용"
        ],
        "rules": [
            "NL 매칭은 greedy하지 않음 — 2개 이상 서브커맨드에 동점 매칭 시 사용자에게 확인",
            "대상 이름 추출: 자연어에서 고유명사/식별자를 추출하여 <name> 인자로 사용",
            "언어 혼합 허용: 한국어+영어 키워드 모두 매칭 대상"
        ]
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Always trigger when matched",
            "high": "Trigger for most matches",
            "medium": "Trigger for clear matches",
            "low": "Trigger only for explicit matches"
        },
        "customization": "Projects can add domain-specific skills by extending this file"
    }
}
