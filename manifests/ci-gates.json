{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCH CI Gates",
  "description": "CI gate definitions per stage (PR, merge, release)",
  "version": "1.0",
  "stages": {
    "local": {
      "description": "개발자 로컬 검증",
      "required_tests": ["contract", "beads"],
      "optional_tests": ["branch", "source_types"],
      "gate": "scripts/test.sh local"
    },
    "pr": {
      "description": "PR 제출 전 검증",
      "required_tests": ["contract", "beads", "branch", "source_types", "vendor_integration"],
      "optional_tests": ["resilience", "dot_gate"],
      "gate": "scripts/test.sh all"
    },
    "merge": {
      "description": "머지 전 최종 검증",
      "required_tests": ["contract", "beads", "branch", "source_types", "vendor_integration", "resilience"],
      "optional_tests": ["dot_gate"],
      "gate": "scripts/test.sh all && scripts/build-release.sh --dry-run"
    },
    "release": {
      "description": "릴리즈 번들 검증",
      "required_tests": ["contract", "beads", "branch", "source_types", "vendor_integration", "resilience", "dot_gate"],
      "additional_checks": ["lock_integrity", "bundle_smoke"],
      "gate": "scripts/test.sh all && scripts/build-release.sh"
    }
  }
}
