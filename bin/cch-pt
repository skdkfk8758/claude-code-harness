#!/usr/bin/env bash
# bin/cch-pt — PinchTab 헬퍼 스크립트
# PinchTab v0.7.x bridge 모드 기반 — flat API + CLI 래퍼
set -euo pipefail

PT_PORT="${PT_PORT:-9867}"
PT_HOST="http://localhost:${PT_PORT}"
PT_TIMEOUT="${PT_TIMEOUT:-30}"

_log() { echo "[cch-pt] $*" >&2; }

# ── Lifecycle ──

cmd_ensure() {
  local mode="${1:-true}"
  # 1. 설치 확인
  if ! command -v pinchtab &>/dev/null; then
    _log "pinchtab not found, installing via npm..."
    npm install -g pinchtab
  fi
  # 2. 서버 동작 확인
  if curl -sf "${PT_HOST}/health" &>/dev/null; then
    _log "PinchTab already running on port ${PT_PORT}"
    curl -sf "${PT_HOST}/health"
    return 0
  fi
  # 3. 서버 시작 (bridge 모드)
  _log "Starting PinchTab (headless=${mode}, port=${PT_PORT})..."
  BRIDGE_HEADLESS="${mode}" BRIDGE_PORT="${PT_PORT}" pinchtab &
  local pid=$!
  # 4. 대기
  local retries=0
  while [ $retries -lt 10 ]; do
    sleep 1
    if curl -sf "${PT_HOST}/health" &>/dev/null; then
      _log "PinchTab ready (pid=${pid}, port=${PT_PORT})"
      curl -sf "${PT_HOST}/health"
      return 0
    fi
    retries=$((retries + 1))
  done
  _log "ERROR: PinchTab failed to start within 10 seconds"
  return 1
}

cmd_health() {
  if curl -sf "${PT_HOST}/health" 2>/dev/null; then
    return 0
  else
    _log "PinchTab is not running on port ${PT_PORT}"
    return 1
  fi
}

cmd_cleanup() {
  _log "Closing all tabs..."
  local tabs
  tabs=$(curl -sf "${PT_HOST}/tabs" 2>/dev/null || echo '{"tabs":[]}')
  echo "$tabs" | jq -r '.tabs[].id // empty' 2>/dev/null | while read -r id; do
    pinchtab tabs close "$id" &>/dev/null && _log "Closed tab ${id}"
  done
  _log "Killing PinchTab server..."
  pkill -f "pinchtab" 2>/dev/null || true
  _log "Cleanup complete"
}

# ── Tabs ──

cmd_tabs() {
  curl -sf "${PT_HOST}/tabs" 2>/dev/null || echo '{"tabs":[]}'
}

cmd_new_tab() {
  local url="${1:-}"
  if [ -n "$url" ]; then
    pinchtab tabs new "$url" 2>&1
  else
    pinchtab tabs new 2>&1
  fi
}

cmd_close_tab() {
  local tab_id="$1"
  pinchtab tabs close "$tab_id" 2>&1
}

# ── Navigation ──

cmd_nav() {
  local url="$1"
  local wait="${2:-3}"
  local tab_id="${3:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab nav ${tab_param} "$url" 2>&1
  [ "$wait" -gt 0 ] 2>/dev/null && sleep "$wait"
  return 0
}

# ── Snapshot ──

cmd_snap() {
  local filter="${1:-}"
  local tab_id="${2:-}"
  local args=""
  case "$filter" in
    interactive) args="-i -c" ;;
    compact)     args="-c" ;;
    diff)        args="-d" ;;
    *)           ;;
  esac
  [ -n "$tab_id" ] && args="${args} --tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab snap ${args} 2>&1
}

# ── Actions ──

cmd_click() {
  local ref="$1"
  local tab_id="${2:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab click ${tab_param} "$ref" 2>&1
}

cmd_fill() {
  local ref="$1"
  local text="$2"
  local tab_id="${3:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab fill ${tab_param} "$ref" "$text" 2>&1
}

cmd_press() {
  local key="$1"
  local tab_id="${2:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab press ${tab_param} "$key" 2>&1
}

cmd_type() {
  local ref="$1"
  local text="$2"
  local tab_id="${3:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab type ${tab_param} "$ref" "$text" 2>&1
}

# ── Data Extraction ──

cmd_text() {
  local tab_id="${1:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab text ${tab_param} 2>&1
}

cmd_screenshot() {
  local output="${1:-screenshot.png}"
  local tab_id="${2:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab ss ${tab_param} -o "$output" 2>&1
}

cmd_eval() {
  local expression="$1"
  local tab_id="${2:-}"
  local tab_param=""
  [ -n "$tab_id" ] && tab_param="--tab ${tab_id}"
  # shellcheck disable=SC2086
  pinchtab eval ${tab_param} "$expression" 2>&1
}

# ── Session ──

cmd_session_init() {
  local session_dir="/tmp/cch-pt-session-$(date +%s)"
  mkdir -p "${session_dir}/screenshots" "${session_dir}/snapshots"
  echo "$session_dir"
}

# ── Main ──
case "${1:-help}" in
  ensure)      cmd_ensure "${2:-true}" ;;
  health)      cmd_health ;;
  cleanup)     cmd_cleanup ;;
  tabs)        cmd_tabs ;;
  new-tab)     cmd_new_tab "${2:-}" ;;
  close-tab)   cmd_close_tab "$2" ;;
  nav)         cmd_nav "$2" "${3:-3}" "${4:-}" ;;
  snap)        cmd_snap "${2:-}" "${3:-}" ;;
  click)       cmd_click "$2" "${3:-}" ;;
  fill)        cmd_fill "$2" "$3" "${4:-}" ;;
  press)       cmd_press "$2" "${3:-}" ;;
  type)        cmd_type "$2" "$3" "${4:-}" ;;
  text)        cmd_text "${2:-}" ;;
  screenshot)  cmd_screenshot "${2:-screenshot.png}" "${3:-}" ;;
  eval)        cmd_eval "$2" "${3:-}" ;;
  session-init) cmd_session_init ;;
  help|*)
    cat <<'USAGE'
Usage: cch-pt <command> [args...]

Lifecycle:
  ensure [headless]        Ensure PinchTab is installed and running (bridge mode)
  health                   Check server health
  cleanup                  Close all tabs and stop server

Tabs:
  tabs                     List all open tabs
  new-tab [url]            Open new tab (optionally navigate to url)
  close-tab <tabId>        Close a tab

Navigation:
  nav <url> [wait] [tabId]       Navigate to URL (default wait: 3s)
  snap [filter] [tabId]          Get page snapshot (filter: interactive|compact|diff)
  click <ref> [tabId]            Click element by ref
  fill <ref> <text> [tabId]      Fill input by ref
  type <ref> <text> [tabId]      Type into element
  press <key> [tabId]            Press key (Enter, Tab, Escape...)

Data:
  text [tabId]                   Extract readable text
  screenshot [path] [tabId]      Take screenshot (default: screenshot.png)
  eval <expression> [tabId]      Run JavaScript expression

Session:
  session-init             Create temp session directory

Environment:
  PT_PORT    Server port (default: 9867)
  PT_TIMEOUT Request timeout in seconds (default: 30)
USAGE
    ;;
esac
