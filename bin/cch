#!/usr/bin/env bash
# cch - Claude Code Harness internal engine
# Usage: cch <command> [options]

set -euo pipefail

CCH_VERSION="0.2.0"
CCH_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CCH_STATE_DIR="${CCH_STATE_DIR:-.claude/cch}"
CCH_LIB_DIR="$CCH_ROOT/bin/lib"

# --- Load modules ---
# shellcheck source=lib/log.sh
[[ -f "$CCH_LIB_DIR/log.sh" ]] && source "$CCH_LIB_DIR/log.sh"
# shellcheck source=lib/sources.sh
[[ -f "$CCH_LIB_DIR/sources.sh" ]] && source "$CCH_LIB_DIR/sources.sh"
# shellcheck source=lib/branch.sh
[[ -f "$CCH_LIB_DIR/branch.sh" ]] && source "$CCH_LIB_DIR/branch.sh"
# shellcheck source=lib/arch.sh
[[ -f "$CCH_LIB_DIR/arch.sh" ]] && source "$CCH_LIB_DIR/arch.sh"
# shellcheck source=lib/beads.sh
[[ -f "$CCH_LIB_DIR/beads.sh" ]] && source "$CCH_LIB_DIR/beads.sh"
# shellcheck source=lib/lock.sh
[[ -f "$CCH_LIB_DIR/lock.sh" ]] && source "$CCH_LIB_DIR/lock.sh"
# shellcheck source=lib/kpi.sh
[[ -f "$CCH_LIB_DIR/kpi.sh" ]] && source "$CCH_LIB_DIR/kpi.sh"

# --- State helpers ---

ensure_state_dir() {
  mkdir -p "$CCH_STATE_DIR"
}

# Ensure all namespaced state directories exist per Architecture spec:
#   .claude/cch/
#   ├── init/           # cch-init state (scan-result, progress, mode)
#   ├── state/          # runtime state (resolve results, execution logs)
#   │   ├── .resolved   # resolve cache
#   │   └── logs/       # execution logs
#   ├── integrity.json  # source integrity checksums
#   └── execution-plan.json  # current execution plan
_ensure_state_dirs() {
  mkdir -p "$CCH_STATE_DIR/init"
  mkdir -p "$CCH_STATE_DIR/state/.resolved"
  mkdir -p "$CCH_STATE_DIR/state/logs"
}

read_state() {
  local key="$1"
  local file="$CCH_STATE_DIR/$key"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo ""
  fi
}

write_state() {
  local key="$1"
  local value="$2"
  ensure_state_dir
  echo "$value" > "$CCH_STATE_DIR/$key"
}

# --- Standard Reason Codes ---
# Format: RC_<CATEGORY>:<detail>
# Used by: cmd_resolve, cmd_setup, cmd_status, log_end
RC_ALL_OK="RC_ALL_OK"                           # Healthy: all sources available
RC_SRC_UNAVAILABLE="RC_SRC_UNAVAILABLE"         # Degraded: source unavailable (append :src:impact)
RC_SRC_BLOCKED="RC_SRC_BLOCKED"                 # Blocked: critical source blocked (append :src)
RC_MISSING_DIR="RC_MISSING_DIR"                 # Blocked: required directory missing (append :dirs)
RC_ROLLBACK_RESTORED="RC_ROLLBACK_RESTORED"     # Info: state restored from rollback
RC_INTEGRITY_FAIL="RC_INTEGRITY_FAIL"           # Blocked: integrity check failed
RC_LOCK_CHANGED="RC_LOCK_CHANGED"               # Degraded: file changed vs release.lock
RC_LOCK_MISSING="RC_LOCK_MISSING"               # Degraded: file in release.lock but missing on disk
RC_LOCK_OK="RC_LOCK_OK"                         # OK: all files match release.lock
RC_ARCH_NOT_SET="RC_ARCH_NOT_SET"               # Info: architecture level not configured
RC_ARCH_CHECK_FAIL="RC_ARCH_CHECK_FAIL"         # Degraded: structure check failed
RC_TDD_NO_TESTS="RC_TDD_NO_TESTS"              # Warn: source files without tests
RC_TDD_LOW_RATIO="RC_TDD_LOW_RATIO"            # Warn: test ratio below threshold
RC_TDD_PASS="RC_TDD_PASS"                      # OK: TDD checks passed

# Write health state with mandatory reason_code
# Usage: write_health <status> <reason_code1> [reason_code2] ...
write_health() {
  local status="$1"; shift
  local codes=("$@")
  write_state "health" "$status"
  if [[ ${#codes[@]} -gt 0 ]]; then
    write_state "health_reason" "$(IFS=','; echo "${codes[*]}")"
  else
    write_state "health_reason" "$RC_ALL_OK"
  fi
}

# Read health reason codes as array (sets HEALTH_REASON_CODES)
# Usage: read_health_reasons; for rc in "${HEALTH_REASON_CODES[@]}"; do ...
read_health_reasons() {
  local raw
  raw="$(read_state health_reason)"
  HEALTH_REASON_CODES=()
  if [[ -n "$raw" ]]; then
    IFS=',' read -ra HEALTH_REASON_CODES <<< "$raw"
  fi
}

# --- Capability Resolver ---

# Parse JSON value without jq (portable)
json_val() {
  local file="$1" key="$2"
  sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$file" | head -1
}

json_bool() {
  local file="$1" key="$2"
  sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p" "$file" | head -1
}

# Get capability sources for current mode from profile
# Outputs two sections separated by "---secondary---":
#   line 1..N: primary sources (one per line)
#   "---secondary---"
#   line N+2..: secondary sources (one per line)
get_mode_sources() {
  local mode="$1"
  local profile="$CCH_ROOT/profiles/$mode.json"
  if [[ ! -f "$profile" ]]; then
    echo ""
    return
  fi
  # Extract primary array values (sorted for deterministic ordering)
  grep -o '"primary"[[:space:]]*:[[:space:]]*\[[^]]*\]' "$profile" \
    | grep -o '"[^"]*"' | tr -d '"' | grep -v "primary" | sort
  echo "---secondary---"
  # Extract secondary array values (sorted for deterministic ordering)
  grep -o '"secondary"[[:space:]]*:[[:space:]]*\[[^]]*\]' "$profile" \
    | grep -o '"[^"]*"' | tr -d '"' | grep -v "secondary" | sort
}

# Standard project-level source paths (checked alongside plugin-level paths)
CCH_SOURCES_DIR="${CCH_STATE_DIR}/sources"

# Extract install_type for a given source_id from manifests/sources.json
# Usage: get_source_install_type <source_id>
# Prints the install_type string, or empty string if not found
get_source_install_type() {
  local source_id="$1"
  local sources_file="$CCH_ROOT/manifests/sources.json"
  if [[ ! -f "$sources_file" ]]; then
    echo ""
    return 0
  fi
  # Find the block for source_id, then extract install_type from it
  # Uses sed/grep only, no jq dependency
  local in_block=0
  local brace_depth=0
  local install_type=""
  while IFS= read -r line; do
    # Detect entry into source block: line like "  \"source_id\": {"
    if [[ $in_block -eq 0 ]] && echo "$line" | grep -qE "\"${source_id}\"[[:space:]]*:[[:space:]]*\{"; then
      in_block=1
      brace_depth=1
      continue
    fi
    if [[ $in_block -eq 1 ]]; then
      # Track brace depth to know when the block ends
      local open_braces close_braces
      open_braces=$(echo "$line" | grep -o '{' | wc -l | tr -d ' ')
      close_braces=$(echo "$line" | grep -o '}' | wc -l | tr -d ' ')
      brace_depth=$(( brace_depth + open_braces - close_braces ))
      if [[ $brace_depth -le 0 ]]; then
        break
      fi
      # Extract install_type value within this block
      if echo "$line" | grep -qE '"install_type"'; then
        install_type=$(echo "$line" | sed 's/.*"install_type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
      fi
    fi
  done < "$sources_file"
  echo "$install_type"
}

# LAST_CHECK_DETAIL is set by check_source_available() to describe why a check failed.
# Callers (cmd_resolve, cmd_doctor) can inspect it for richer diagnostics.
LAST_CHECK_DETAIL=""

# Check if a capability source is available
# Sets LAST_CHECK_DETAIL on failure with a reason code string.
# Searches: sources.json path (SSOT) → overlay fallback, branches on install_type.
check_source_available() {
  local source="$1"
  LAST_CHECK_DETAIL=""

  # DOT is special (requires dot_enabled state)
  if [[ "$source" == "dot" || "$source" == "dance-of-tal" ]]; then
    if [[ -d ".dance-of-tal" || -d "$CCH_ROOT/dot" ]] && [[ "$(read_state dot_enabled)" == "true" ]]; then
      return 0
    fi
    LAST_CHECK_DETAIL="local_missing"
    return 1
  fi

  # Determine install_type for this source
  local install_type
  install_type="$(get_source_install_type "$source")"

  # 1) sources.json-based path check (SSOT)
  if type sources_resolve_path &>/dev/null; then
    local path
    path="$(sources_resolve_path "$source" 2>/dev/null)" || true
    if [[ -n "$path" ]]; then
      case "$install_type" in
        plugin)
          # For plugin sources: check installed_plugins.json for plugin_id
          local plugins_file="$HOME/.claude/plugins/installed_plugins.json"
          local plugin_id
          plugin_id="$(grep -A20 "\"${source}\"" "$CCH_ROOT/manifests/sources.json" 2>/dev/null \
            | grep '"plugin_id"' \
            | sed 's/.*"plugin_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
            | head -1)"
          if [[ -f "$plugins_file" ]]; then
            if [[ -n "$plugin_id" ]] && grep -qF "\"$plugin_id\"" "$plugins_file" 2>/dev/null; then
              return 0
            fi
            LAST_CHECK_DETAIL="plugin_not_installed"
            return 1
          fi
          # plugins file absent — fall through to directory check as best-effort
          if [[ -d "$path" && -d "$path/.git" ]]; then
            return 0
          fi
          LAST_CHECK_DETAIL="plugin_not_installed"
          return 1
          ;;
        npm)
          if [[ -d "$path" && -d "$path/.git" ]]; then
            if [[ -d "$path/node_modules" ]]; then
              return 0
            fi
            LAST_CHECK_DETAIL="npm_deps_missing"
            return 1
          fi
          LAST_CHECK_DETAIL="not_cloned"
          return 1
          ;;
        git)
          if [[ -d "$path" && -d "$path/.git" ]]; then
            return 0
          fi
          LAST_CHECK_DETAIL="not_cloned"
          return 1
          ;;
        local)
          if [[ -d "$path" ]]; then
            return 0
          fi
          LAST_CHECK_DETAIL="local_missing"
          return 1
          ;;
        *)
          # Unknown/empty install_type: fall back to original .git check
          if [[ -d "$path" && -d "$path/.git" ]]; then
            return 0
          fi
          LAST_CHECK_DETAIL="not_cloned"
          return 1
          ;;
      esac
    fi
  fi

  # 2) CCH_SOURCES_DIR fallback
  if [[ -d "$CCH_SOURCES_DIR/$source" ]]; then
    if [[ "$install_type" == "npm" ]]; then
      if [[ -d "$CCH_SOURCES_DIR/$source/.git" ]]; then
        if [[ -d "$CCH_SOURCES_DIR/$source/node_modules" ]]; then
          return 0
        fi
        LAST_CHECK_DETAIL="npm_deps_missing"
        return 1
      fi
      LAST_CHECK_DETAIL="not_cloned"
      return 1
    fi
    if [[ -d "$CCH_SOURCES_DIR/$source/.git" ]]; then
      return 0
    fi
    LAST_CHECK_DETAIL="not_cloned"
    return 1
  fi

  # 3) overlay fallback (overlays are local, no .git required)
  if [[ -d "$CCH_ROOT/overlays/$source" || -d "overlays/$source" ]]; then
    return 0
  fi

  LAST_CHECK_DETAIL="not_cloned"
  return 1
}

# Health rules file path
HEALTH_RULES_FILE="$CCH_ROOT/manifests/health-rules.json"

# Look up health rule for a source+mode pair from health-rules.json
# Sets: _RULE_HEALTH, _RULE_IMPACT, _RULE_REASON_CODE
# Returns 0 if rule found, 1 if not (fallback applies)
get_health_rule() {
  local source="$1" mode="$2"
  # Defaults (safe fallback per fallback_policy=degrade)
  _RULE_HEALTH="Degraded"
  _RULE_IMPACT="unknown"
  _RULE_REASON_CODE="$RC_SRC_UNAVAILABLE"

  if [[ ! -f "$HEALTH_RULES_FILE" ]]; then
    return 1
  fi

  # Find matching rule: source matches AND modes array contains current mode
  # Parse rules using sed/grep (no jq dependency)
  local rule_block
  rule_block="$(sed -n "/\"source\"[[:space:]]*:[[:space:]]*\"$source\"/,/}/p" "$HEALTH_RULES_FILE")"
  if [[ -z "$rule_block" ]]; then
    return 1
  fi

  # Check if mode matches (mode appears in "modes" array)
  if ! echo "$rule_block" | grep -q "\"$mode\""; then
    # Source has rule but not for this mode → use capabilities.json fallback
    _fallback_from_capabilities "$source"
    return 1
  fi

  # Extract fields from matching rule
  local h i rc
  h="$(echo "$rule_block" | sed -n 's/.*"health"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  i="$(echo "$rule_block" | sed -n 's/.*"impact"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  rc="$(echo "$rule_block" | sed -n 's/.*"reason_code"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"

  _RULE_HEALTH="${h:-Degraded}"
  _RULE_IMPACT="${i:-unknown}"
  _RULE_REASON_CODE="${rc:-$RC_SRC_UNAVAILABLE}"
  return 0
}

# Fallback: read severity/impact from capabilities.json when no health-rule matches
_fallback_from_capabilities() {
  local source="$1"
  local manifest="$CCH_ROOT/manifests/capabilities.json"
  [[ ! -f "$manifest" ]] && return

  local sev
  sev="$(sed -n "/$source/,/severity/s/.*\"severity\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$manifest" | head -1)"
  local impact
  impact="$(sed -n "/$source/,/fallback_impact/s/.*\"fallback_impact\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$manifest" | head -1)"

  if [[ "$sev" == "blocked" ]]; then
    _RULE_HEALTH="Blocked"
    _RULE_REASON_CODE="$RC_SRC_BLOCKED"
  else
    _RULE_HEALTH="Degraded"
    _RULE_REASON_CODE="$RC_SRC_UNAVAILABLE"
  fi
  _RULE_IMPACT="${impact:-unknown}"
}

# Resolve capabilities for a mode and write to .resolved/
_do_resolve() {
  local mode="${1:-}"
  if [[ -z "$mode" ]]; then
    mode="$(read_state mode)"
  fi

  if [[ -z "$mode" ]]; then
    echo "[cch] ERROR: No mode set. Run 'cch setup' first."
    return 1
  fi

  local resolved_dir="$CCH_STATE_DIR/.resolved"
  mkdir -p "$resolved_dir"

  local sources
  sources="$(get_mode_sources "$mode")"

  # Split get_mode_sources output into primary and secondary lists
  local primary_sources=()
  local secondary_sources=()
  local in_secondary=0
  while IFS= read -r line; do
    if [[ "$line" == "---secondary---" ]]; then
      in_secondary=1
      continue
    fi
    [[ -z "$line" ]] && continue
    if [[ "$in_secondary" -eq 0 ]]; then
      primary_sources+=("$line")
    else
      secondary_sources+=("$line")
    fi
  done <<< "$sources"

  local available=()
  local degraded=()
  local health="Healthy"
  local reasons=()

  # Process primary sources — unavailable can result in Blocked
  for src in "${primary_sources[@]+"${primary_sources[@]}"}"; do
    [[ -z "$src" ]] && continue
    if check_source_available "$src"; then
      available+=("$src")
    else
      degraded+=("$src")
      get_health_rule "$src" "$mode" || true
      reasons+=("${_RULE_REASON_CODE}:${src}:${_RULE_IMPACT}")
      if [[ "$_RULE_HEALTH" == "Blocked" ]]; then
        health="Blocked"
      fi
    fi
  done

  # Process secondary sources — unavailable is capped at Degraded (never Blocked)
  for src in "${secondary_sources[@]+"${secondary_sources[@]}"}"; do
    [[ -z "$src" ]] && continue
    if check_source_available "$src"; then
      available+=("$src")
    else
      degraded+=("$src")
      get_health_rule "$src" "$mode" || true
      # Cap secondary source impact: never escalate to Blocked
      local sec_rc="${_RULE_REASON_CODE}"
      local sec_impact="${_RULE_IMPACT}"
      if [[ "$sec_rc" == "$RC_SRC_BLOCKED" ]]; then
        sec_rc="$RC_SRC_UNAVAILABLE"
      fi
      reasons+=("${sec_rc}:${src}:${sec_impact}")
    fi
  done

  # Determine health: Blocked (primary only, set above) > Degraded > Healthy
  if [[ "$health" != "Blocked" && ${#degraded[@]} -gt 0 ]]; then
    health="Degraded"
  fi

  # Write health with mandatory reason_code
  if [[ ${#reasons[@]} -gt 0 ]]; then
    write_health "$health" "${reasons[@]}"
  else
    write_health "$health" "$RC_ALL_OK"
  fi

  # Sort arrays for deterministic output
  if [[ ${#available[@]} -gt 0 ]]; then
    IFS=$'\n' available=($(sort <<<"${available[*]}")); unset IFS
  fi
  if [[ ${#degraded[@]} -gt 0 ]]; then
    IFS=$'\n' degraded=($(sort <<<"${degraded[*]}")); unset IFS
  fi

  # Write resolved manifest (atomic: write to tmp then rename)
  # Guard: ensure .resolved dir exists even if CCH_STATE_DIR was created after
  # the initial mkdir-p above (e.g. concurrent invocations, test isolation).
  mkdir -p "$resolved_dir"
  local tmp_state
  tmp_state="$resolved_dir/state.json.tmp.$$"
  {
    echo "{"
    echo "  \"mode\": \"$mode\","
    echo "  \"resolved_at\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\","
    echo "  \"health\": \"$health\","
    if [[ ${#available[@]} -gt 0 ]]; then
      echo "  \"available\": [$(printf '\"%s\",' "${available[@]}" | sed 's/,$//')],"
    else
      echo "  \"available\": [],"
    fi
    if [[ ${#degraded[@]} -gt 0 ]]; then
      echo "  \"degraded\": [$(printf '\"%s\",' "${degraded[@]}" | sed 's/,$//')],"
    else
      echo "  \"degraded\": [],"
    fi
    if [[ ${#reasons[@]} -gt 0 ]]; then
      echo "  \"reasons\": [$(printf '\"%s\",' "${reasons[@]}" | sed 's/,$//')]"
    else
      echo "  \"reasons\": []"
    fi
    echo "}"
  } > "$tmp_state"
  mv -f "$tmp_state" "$resolved_dir/state.json"

  echo "[cch] Resolved: mode=$mode health=$health available=[${available[*]:-}] degraded=[${degraded[*]:-}]"
}

cmd_resolve() {
  if type lock_run &>/dev/null; then
    lock_run "resolve" _do_resolve "$@"
  else
    _do_resolve "$@"
  fi
}

# --- Commands ---

cmd_setup() {
  local skip_sources=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-fetch) skip_sources=true; shift ;;
      *) shift ;;
    esac
  done

  echo "[cch] Setting up Claude Code Harness v${CCH_VERSION}..."
  ensure_state_dir
  _ensure_state_dirs

  # Check required directories
  local missing=()
  for dir in profiles manifests; do
    if [[ ! -d "$CCH_ROOT/$dir" ]]; then
      missing+=("$dir")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "[cch] ERROR: Missing directories: ${missing[*]}"
    write_health "Blocked" "${RC_MISSING_DIR}:${missing[*]}"
    return 1
  fi

  # Check profiles
  local modes=("plan" "code" "tool" "swarm")
  for mode in "${modes[@]}"; do
    if [[ ! -f "$CCH_ROOT/profiles/$mode.json" ]]; then
      echo "[cch] WARN: Missing profile for mode: $mode"
    fi
  done

  # Auto-install external sources
  if [[ "$skip_sources" == "false" ]]; then
    if type sources_install_all &>/dev/null; then
      echo ""
      sources_install_all
      echo ""
    else
      echo "[cch] WARN: Source installer unavailable (bin/lib/sources.sh missing)"
      echo "[cch]   External sources will not be auto-installed."
      echo "[cch]   Overlay fallback only."
    fi
  fi

  # Initialize default state (health is determined by cmd_resolve below)
  write_state "dot_enabled" "false"

  local current_mode
  current_mode="$(read_state mode)"
  if [[ -z "$current_mode" ]]; then
    write_state "mode" "code"
    echo "[cch] Default mode set to: code"
  fi

  # Resolve capabilities for current mode
  current_mode="$(read_state mode)"
  cmd_resolve "$current_mode" 2>/dev/null || true

  # Auto-sync skills to plugin cache
  if type sync_skills &>/dev/null; then
    echo "[cch] Syncing skills to plugin cache..."
    sync_skills 2>/dev/null || echo "[cch] WARN: Skill sync skipped (plugin not installed yet)"
  fi

  echo ""
  echo "[cch] Setup complete. State dir: $CCH_STATE_DIR"

  # Post-setup guidance
  if check_source_available "omc" 2>/dev/null; then
    if [[ ! -f "$HOME/.claude/CLAUDE.md" ]] || ! grep -q "<!-- OMC:START -->" "$HOME/.claude/CLAUDE.md" 2>/dev/null; then
      echo "[cch] TIP: OMC가 설치되었지만 글로벌 설정이 없습니다."
      echo "[cch]   /omc-setup 을 실행하여 ~/.claude/CLAUDE.md 를 구성하세요."
    fi
  fi

  echo "[cch] Run 'cch doctor --summary' to check status."
}

cmd_mode() {
  local target_mode="${1:-}"
  local valid_modes=("plan" "code" "tool" "swarm")

  if [[ -z "$target_mode" ]]; then
    local current
    current="$(read_state mode)"
    echo "[cch] Current mode: ${current:-not set}"
    return 0
  fi

  # Validate mode
  local valid=false
  for m in "${valid_modes[@]}"; do
    if [[ "$target_mode" == "$m" ]]; then
      valid=true
      break
    fi
  done

  if [[ "$valid" == "false" ]]; then
    echo "[cch] ERROR: Invalid mode '$target_mode'. Valid: ${valid_modes[*]}"
    return 1
  fi

  # Check profile exists
  if [[ ! -f "$CCH_ROOT/profiles/$target_mode.json" ]]; then
    echo "[cch] ERROR: Profile not found: profiles/$target_mode.json"
    return 1
  fi

  # Disable DOT if switching away from code mode
  if [[ "$target_mode" != "code" ]]; then
    local dot_enabled
    dot_enabled="$(read_state dot_enabled)"
    if [[ "$dot_enabled" == "true" ]]; then
      write_state "dot_enabled" "false"
      echo "[cch] DOT disabled (not available in $target_mode mode)"
    fi
  fi

  local prev_mode
  prev_mode="$(read_state mode)"
  write_state "mode" "$target_mode"
  echo "[cch] Mode changed: ${prev_mode:-none} -> $target_mode"

  # Auto-create PLAN document when switching to plan mode
  if [[ "$target_mode" == "plan" ]]; then
    _auto_create_plan_doc
  fi

  # Re-resolve capabilities for new mode
  cmd_resolve "$target_mode"
}

_auto_create_plan_doc() {
  local plans_dir="$CCH_ROOT/docs/plans"
  mkdir -p "$plans_dir"

  local today
  today="$(date -u +%Y-%m-%d)"

  # Find active bead for plan naming
  local work_id="general"
  local exec_plan="$CCH_STATE_DIR/execution-plan.json"
  if [[ -f "$exec_plan" ]]; then
    local bead_id
    bead_id="$(sed -n 's/.*"bead_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$exec_plan" | head -1)"
    if [[ -n "$bead_id" ]]; then
      work_id="$bead_id"
    fi
  fi

  local plan_file="$plans_dir/${today}-${work_id}.md"

  # Skip if document already exists
  if [[ -f "$plan_file" ]]; then
    echo "[cch] PLAN document exists: $(basename "$plan_file")"
    return 0
  fi

  # Generate template
  cat > "$plan_file" <<PLANEOF
# Plan: ${work_id}

> Created: ${today}
> Work Item: ${work_id}
> Status: draft

## Goal

<!-- What is the objective of this plan? -->

## Context

<!-- Current state, constraints, dependencies -->

## Approach

<!-- Step-by-step approach -->

### Phase 1

- [ ] Step 1

### Phase 2

- [ ] Step 2

## Risks

<!-- Known risks and mitigations -->

## Acceptance Criteria

- [ ] Criterion 1

## Notes

<!-- Additional notes -->
PLANEOF

  echo "[cch] PLAN document created: $(basename "$plan_file")"
}

cmd_status() {
  local output_json=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) output_json=true; shift ;;
      *) shift ;;
    esac
  done

  local mode health health_reason dot_enabled dot_compiled
  mode="$(read_state mode)"
  health="$(read_state health)"
  health_reason="$(read_state health_reason)"
  dot_enabled="$(read_state dot_enabled)"
  dot_compiled="$(read_state dot_compiled)"

  if [[ "$output_json" == "true" ]]; then
    status_json "$mode" "$health" "$health_reason" "$dot_enabled" "$dot_compiled"
    return 0
  fi

  echo "=== CCH Status ==="
  echo "Version:     $CCH_VERSION"
  echo "Mode:        ${mode:-not set}"
  echo "Health:      ${health:-Unknown}"
  echo "DOT:         ${dot_enabled:-false}"

  # Arch Level + TDD status (only if arch module loaded)
  if type arch_current_level &>/dev/null; then
    local arch_level arch_name
    arch_level="$(arch_current_level)"
    if [[ -n "$arch_level" ]]; then
      arch_name="$(arch_level_name "$arch_level")"
      echo "Arch Level:  $arch_level ($arch_name)"
    else
      echo "Arch Level:  not set"
    fi
    echo "TDD:         always ON"
  fi

  # G11: Branch info (only if branch module loaded)
  if type branch_base &>/dev/null; then
    local current_branch
    current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    echo "Branch:      ${current_branch:-detached}"
    local sf="$CCH_STATE_DIR/branches/$(branch_state_filename "$current_branch" 2>/dev/null).yaml"
    if [[ -f "$sf" ]]; then
      echo "Work-Item:   $(yaml_get "$sf" "work_id")"
    fi
  fi

  # Fallback details
  if [[ -n "$health_reason" && "$health_reason" != "$RC_ALL_OK" ]]; then
    echo ""
    echo "=== Reason Codes ==="
    read_health_reasons
    for rc in "${HEALTH_REASON_CODES[@]}"; do
      echo "  - $rc"
    done
  fi

  # Capability sources
  echo ""
  echo "=== Capabilities ==="
  if [[ -f "$CCH_ROOT/manifests/capabilities.json" ]]; then
    echo "Manifest:    loaded"
  else
    echo "Manifest:    MISSING"
  fi

  if [[ -n "$mode" && -f "$CCH_ROOT/profiles/$mode.json" ]]; then
    echo "Profile:     profiles/$mode.json (loaded)"
  elif [[ -n "$mode" ]]; then
    echo "Profile:     profiles/$mode.json (MISSING)"
  fi

  # Show source availability for current mode
  if [[ -n "$mode" ]]; then
    local sources
    sources="$(get_mode_sources "$mode")"
    if [[ -n "$sources" ]]; then
      echo ""
      echo "=== Sources ($mode) ==="
      while IFS= read -r src; do
        [[ -z "$src" ]] && continue
        if check_source_available "$src"; then
          echo "  [OK]   $src"
        else
          local impact
          impact="$(get_fallback_impact "$src")"
          echo "  [MISS] $src -> $impact"
        fi
      done <<< "$sources"
    fi
  fi

  # Resolved state
  if [[ -f "$CCH_STATE_DIR/.resolved/state.json" ]]; then
    echo ""
    echo "=== Resolved ==="
    echo "  File: $CCH_STATE_DIR/.resolved/state.json (present)"
  fi
}

status_json() {
  local mode="$1" health="$2" health_reason="$3" dot_enabled="$4" dot_compiled="$5"

  # Collect resolved state
  local resolved_json="{}"
  if [[ -f "$CCH_STATE_DIR/.resolved/state.json" ]]; then
    resolved_json="$(cat "$CCH_STATE_DIR/.resolved/state.json")"
  fi

  # Collect active beads
  local work_items="[]"
  if type beads_list &>/dev/null; then
    work_items="$(bd list --json 2>/dev/null || echo "[]")"
  fi

  # Collect active plans
  local plans="[]"
  local plan_files
  plan_files="$(find "$CCH_ROOT/docs/plans" -name '*.md' -type f 2>/dev/null | sort)" || true
  if [[ -n "$plan_files" ]]; then
    local plan_items=()
    while IFS= read -r pf; do
      [[ -z "$pf" ]] && continue
      local pname
      pname="$(basename "$pf")"
      plan_items+=("\"$pname\"")
    done <<< "$plan_files"
    if [[ ${#plan_items[@]} -gt 0 ]]; then
      plans="[$(IFS=,; echo "${plan_items[*]}")]"
    fi
  fi

  # Reason codes (always populated via write_health)
  local reason_codes="[]"
  if [[ -n "$health_reason" ]]; then
    read_health_reasons
    local rc_items=()
    for rc in "${HEALTH_REASON_CODES[@]}"; do
      rc_items+=("\"$rc\"")
    done
    reason_codes="[$(IFS=,; echo "${rc_items[*]}")]"
  fi

  # Collect per-source check details from sources.json
  local source_details="{}"
  local sources_manifest="$CCH_ROOT/manifests/sources.json"
  if [[ -f "$sources_manifest" ]]; then
    local src_ids
    src_ids="$(sed -n 's/^[[:space:]]*"\([^"]*\)"[[:space:]]*:[[:space:]]*{.*/\1/p' "$sources_manifest" \
      | grep -v '^sources$')"
    local sd_entries=()
    while IFS= read -r src_id; do
      [[ -z "$src_id" ]] && continue
      local itype
      itype="$(get_source_install_type "$src_id")"
      local check_ok="false"
      local check_detail=""
      if check_source_available "$src_id"; then
        check_ok="true"
        check_detail="ok"
      else
        check_detail="${LAST_CHECK_DETAIL:-unknown}"
      fi
      sd_entries+=("\"$src_id\":{\"install_type\":\"${itype:-unknown}\",\"ok\":$check_ok,\"check_detail\":\"$check_detail\"}")
    done <<< "$src_ids"
    if [[ ${#sd_entries[@]} -gt 0 ]]; then
      source_details="{$(IFS=,; echo "${sd_entries[*]}")}"
    fi
  fi

  # Output JSON
  cat <<ENDJSON
{
  "version": "$CCH_VERSION",
  "mode": "${mode:-null}",
  "health": "${health:-Unknown}",
  "reason_codes": $reason_codes,
  "dot": {
    "enabled": ${dot_enabled:-false},
    "compiled": "${dot_compiled:-false}"
  },
  "resolved": $resolved_json,
  "work_items": $work_items,
  "plans": $plans,
  "source_details": $source_details
}
ENDJSON
}

cmd_doctor() {
  local do_fix=false
  local pass_args=()
  for arg in "$@"; do
    if [[ "$arg" == "--fix" ]]; then
      do_fix=true
    else
      pass_args+=("$arg")
    fi
  done

  cmd_status "${pass_args[@]+"${pass_args[@]}"}"

  echo ""
  echo "=== CCH Deep Diagnostics ==="
  echo ""

  local warn_count=0
  local err_count=0
  local setup_failed=false

  # Resolve sources root (relative to cwd at runtime, consistent with install)
  local sources_root="${CCH_STATE_DIR}/sources"

  # ── 1. GPTaku submodule initialization ─────────────────────────────────────
  local gptaku_dir="${sources_root}/gptaku_plugins"
  local gptaku_ok=0
  local gptaku_total=0
  if [[ -d "$gptaku_dir/plugins" ]]; then
    for plugin_dir in "$gptaku_dir/plugins"/*/; do
      [[ ! -d "$plugin_dir" ]] && continue
      (( gptaku_total++ ))
      # A non-empty dir means the submodule is initialized
      if [[ -n "$(ls -A "$plugin_dir" 2>/dev/null)" ]]; then
        (( gptaku_ok++ ))
      fi
    done
  fi

  if [[ "$gptaku_total" -eq 0 ]]; then
    if [[ -d "$gptaku_dir" ]]; then
      printf "[OK]   GPTaku submodules initialized (no plugins dir found)\n"
    else
      printf "[WARN] GPTaku source not installed (%s missing)\n" "$gptaku_dir"
      printf "       → Fix: cch sources ensure gptaku_plugins\n"
      (( warn_count++ ))
    fi
  elif [[ "$gptaku_ok" -lt "$gptaku_total" ]]; then
    local gptaku_missing=$(( gptaku_total - gptaku_ok ))
    printf "[WARN] GPTaku submodules not initialized (%d/%d uninitialized)\n" "$gptaku_missing" "$gptaku_total"
    printf "       → Fix: cd %s && git submodule update --init --recursive\n" "$gptaku_dir"
    printf "       → Or run: cch doctor --fix\n"
    (( warn_count++ ))
    if [[ "$do_fix" == "true" ]]; then
      echo "       [FIX] Running git submodule update --init --recursive ..."
      if (cd "$gptaku_dir" && git submodule update --init --recursive 2>&1 | sed 's/^/       /'); then
        echo "       [FIX] Done."
      else
        echo "       [FIX] Failed — check output above."
      fi
    fi
  else
    printf "[OK]   GPTaku submodules initialized (%d/%d)\n" "$gptaku_ok" "$gptaku_total"
  fi

  # ── 2. Ruflo node_modules and CLI ──────────────────────────────────────────
  local ruflo_dir="${sources_root}/ruflo"
  if [[ ! -d "$ruflo_dir" ]]; then
    printf "[WARN] Ruflo source not installed (%s missing)\n" "$ruflo_dir"
    printf "       → Fix: cch sources ensure ruflo\n"
    (( warn_count++ ))
  elif [[ ! -d "$ruflo_dir/node_modules" ]]; then
    printf "[WARN] Ruflo node_modules missing — run: cd %s && npm install\n" "$ruflo_dir"
    printf "       → Or run: cch doctor --fix\n"
    (( warn_count++ ))
    setup_failed=true
    if [[ "$do_fix" == "true" ]]; then
      echo "       [FIX] Running npm install --production ..."
      if (cd "$ruflo_dir" && npm install --production 2>&1 | sed 's/^/       /'); then
        echo "       [FIX] Done."
      else
        echo "       [FIX] Failed — check output above."
      fi
    fi
  elif [[ ! -x "$ruflo_dir/bin/cli.js" && ! -f "$ruflo_dir/bin/cli.js" ]]; then
    printf "[WARN] Ruflo bin/cli.js not found\n"
    printf "       → Expected: %s/bin/cli.js\n" "$ruflo_dir"
    (( warn_count++ ))
  else
    printf "[OK]   Ruflo node_modules present and bin/cli.js exists\n"
  fi

  # ── 3. SKILL.md ↔ source path consistency ──────────────────────────────────
  local skill_ok=0
  local skill_total=0
  local skill_issues=()

  while IFS= read -r skill_md; do
    [[ -z "$skill_md" ]] && continue
    # Extract init-submodule lines: sources init-submodule <source> <subpath>
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local src subpath
      src="$(echo "$line" | sed 's/.*sources init-submodule[[:space:]]*//' | awk '{print $1}')"
      subpath="$(echo "$line" | sed 's/.*sources init-submodule[[:space:]]*//' | awk '{print $2}')"
      [[ -z "$src" || -z "$subpath" ]] && continue
      # Skip template placeholders like plugins/<name>
      [[ "$src" == *"<"* || "$src" == *">"* || "$subpath" == *"<"* || "$subpath" == *">"* ]] && continue
      (( skill_total++ ))
      local full_path="${sources_root}/${src}/${subpath}"
      if [[ -d "$full_path" ]]; then
        (( skill_ok++ ))
      else
        skill_issues+=("$(basename "$(dirname "$skill_md")"): ${src}/${subpath} missing")
      fi
    done < <(grep -o 'sources init-submodule [^`"'"'"' ]*[[:space:]]*[^`"'"'"' ]*' "$skill_md" 2>/dev/null)
  done < <(find "$CCH_ROOT/skills" -name 'SKILL.md' -type f 2>/dev/null)

  if [[ "$skill_total" -eq 0 ]]; then
    printf "[OK]   SKILL.md source paths consistent (no init-submodule references)\n"
  elif [[ ${#skill_issues[@]} -gt 0 ]]; then
    printf "[WARN] SKILL.md source paths inconsistent (%d/%d missing)\n" "${#skill_issues[@]}" "$skill_total"
    for issue in "${skill_issues[@]}"; do
      printf "       → %s\n" "$issue"
    done
    (( warn_count++ ))
  else
    printf "[OK]   SKILL.md source paths consistent (%d/%d)\n" "$skill_ok" "$skill_total"
  fi

  # ── 4. Git remote reachability ─────────────────────────────────────────────
  local remote_ok=0
  local remote_total=0
  local remote_issues=()

  if [[ -d "$sources_root" ]]; then
    for src_dir in "$sources_root"/*/; do
      [[ ! -d "$src_dir/.git" ]] && continue
      (( remote_total++ ))
      local src_name
      src_name="$(basename "$src_dir")"
      local remote_url
      remote_url="$(git -C "$src_dir" remote get-url origin 2>/dev/null)"
      if [[ -n "$remote_url" ]]; then
        (( remote_ok++ ))
      else
        remote_issues+=("$src_name: no origin remote")
      fi
    done
  fi

  if [[ "$remote_total" -eq 0 ]]; then
    printf "[OK]   Git remotes reachable (no git sources found)\n"
  elif [[ ${#remote_issues[@]} -gt 0 ]]; then
    printf "[WARN] Git remote issues (%d/%d sources affected)\n" "${#remote_issues[@]}" "$remote_total"
    for issue in "${remote_issues[@]}"; do
      printf "       → %s\n" "$issue"
    done
    (( warn_count++ ))
  else
    printf "[OK]   Git remotes reachable (%d/%d)\n" "$remote_ok" "$remote_total"
  fi

  # ── 5. Integrity checksum verification ─────────────────────────────────────
  local integrity_file="${CCH_STATE_DIR}/integrity.json"
  if [[ ! -f "$integrity_file" ]]; then
    printf "[OK]   Integrity checksums (no integrity.json present)\n"
  else
    local int_ok=0
    local int_total=0
    local int_issues=()

    # integrity.json format: {"path": "sha256hex", ...}
    # Use python if available, else skip gracefully
    if command -v python3 &>/dev/null; then
      while IFS=$'\t' read -r fpath expected_sum; do
        [[ -z "$fpath" ]] && continue
        (( int_total++ ))
        local abs_path="$CCH_ROOT/$fpath"
        if [[ ! -f "$abs_path" ]]; then
          int_issues+=("$fpath: file missing")
          continue
        fi
        local actual_sum
        actual_sum="$(python3 -c "import hashlib,sys; d=open(sys.argv[1],'rb').read(); print(hashlib.sha256(d).hexdigest())" "$abs_path" 2>/dev/null)"
        if [[ "$actual_sum" == "$expected_sum" ]]; then
          (( int_ok++ ))
        else
          int_issues+=("$fpath: checksum mismatch")
        fi
      done < <(python3 -c "
import json, sys
data = json.load(open(sys.argv[1]))
for k, v in data.items():
    print(k + '\t' + v)
" "$integrity_file" 2>/dev/null)

      if [[ "$int_total" -eq 0 ]]; then
        printf "[OK]   Integrity checksums (integrity.json empty or unparseable)\n"
      elif [[ ${#int_issues[@]} -gt 0 ]]; then
        printf "[ERR]  Integrity checksums failed (%d/%d)\n" "${#int_issues[@]}" "$int_total"
        for issue in "${int_issues[@]}"; do
          printf "       → %s\n" "$issue"
        done
        (( err_count++ ))
      else
        printf "[OK]   Integrity checksums valid (%d/%d)\n" "$int_ok" "$int_total"
      fi
    else
      printf "[OK]   Integrity checksums (python3 not available, skipped)\n"
    fi
  fi

  # ── 6. External Sources (install_type-aware) ────────────────────────────────
  local sources_manifest="$CCH_ROOT/manifests/sources.json"
  if [[ -f "$sources_manifest" ]]; then
    echo ""
    echo "=== External Sources ==="
    # Extract source IDs: lines matching top-level keys under "sources": { "id": {
    local src_ids
    src_ids="$(sed -n 's/^[[:space:]]*"\([^"]*\)"[[:space:]]*:[[:space:]]*{.*/\1/p' "$sources_manifest" \
      | grep -v '^sources$')"
    while IFS= read -r src_id; do
      [[ -z "$src_id" ]] && continue
      local itype
      itype="$(get_source_install_type "$src_id")"
      local itype_label="${itype:-unknown}"
      if check_source_available "$src_id"; then
        printf "  [OK]   %s (%s)\n" "$src_id" "$itype_label"
      else
        local detail="$LAST_CHECK_DETAIL"
        # Determine status label: WARN for partial installs, MISS for not present
        local status_label="MISS"
        if [[ "$detail" == "npm_deps_missing" ]]; then
          status_label="WARN"
        fi
        printf "  [%s]   %s (%s)\n" "$status_label" "$src_id" "$itype_label"
        # Provide type-specific fix hint
        case "$detail" in
          plugin_not_installed)
            local plugin_id
            plugin_id="$(grep -A20 "\"${src_id}\"" "$sources_manifest" 2>/dev/null \
              | grep '"plugin_id"' \
              | sed 's/.*"plugin_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
              | head -1)"
            if [[ -n "$plugin_id" ]]; then
              printf "           → Fix: claude plugin install %s\n" "$plugin_id"
            else
              printf "           → Fix: install plugin for source '%s'\n" "$src_id"
            fi
            (( warn_count++ ))
            ;;
          npm_deps_missing)
            local src_target
            src_target="$(grep -A20 "\"${src_id}\"" "$sources_manifest" 2>/dev/null \
              | grep '"target"' \
              | sed 's/.*"target"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' \
              | head -1)"
            local npm_dir="${src_target:-$CCH_SOURCES_DIR/$src_id}"
            printf "           → Fix: cd %s && npm install --production\n" "$npm_dir"
            (( warn_count++ ))
            ;;
          not_cloned)
            printf "           → Fix: cch sources install %s\n" "$src_id"
            (( warn_count++ ))
            ;;
          local_missing)
            printf "           → Fix: check built-in path for source '%s'\n" "$src_id"
            (( warn_count++ ))
            ;;
          *)
            printf "           → Fix: cch sources install %s\n" "$src_id"
            (( warn_count++ ))
            ;;
        esac
      fi
    done <<< "$src_ids"
  fi

  # ── Summary ────────────────────────────────────────────────────────────────
  echo ""
  printf "Result: %d warning(s), %d error(s)\n" "$warn_count" "$err_count"

  # Return failure if a critical dependency (e.g. node_modules) is missing
  if [[ "$setup_failed" == "true" ]]; then
    return 1
  fi
}

cmd_dot() {
  local action="${1:-}"
  local current_mode
  current_mode="$(read_state mode)"

  if [[ -z "$action" ]]; then
    local dot_enabled
    dot_enabled="$(read_state dot_enabled)"
    echo "[cch] DOT experiment: ${dot_enabled:-false}"
    return 0
  fi

  # DOT is code-mode only
  if [[ "$current_mode" != "code" ]]; then
    echo "[cch] ERROR: DOT experiment is only available in code mode (current: ${current_mode:-not set})"
    return 1
  fi

  case "$action" in
    on|--toggle)
      local current_dot
      current_dot="$(read_state dot_enabled)"
      if [[ "$action" == "--toggle" ]]; then
        if [[ "$current_dot" == "true" ]]; then
          dot_disable
        else
          dot_enable
        fi
      else
        dot_enable
      fi
      ;;
    off)
      dot_disable
      ;;
    status)
      dot_status
      ;;
    *)
      echo "[cch] ERROR: Invalid DOT action '$action'. Use: on|off|status"
      return 1
      ;;
  esac
}

dot_enable() {
  write_state "dot_enabled" "true"
  echo "[cch] DOT experiment: ON"

  # DOT compile: check for DOT sources and build routing
  dot_compile

  # Re-resolve with DOT active
  cmd_resolve "$(read_state mode)"
}

dot_disable() {
  write_state "dot_enabled" "false"
  echo "[cch] DOT experiment: OFF"

  # Re-resolve without DOT
  cmd_resolve "$(read_state mode)"
}

dot_compile() {
  local dot_dir="$CCH_ROOT/dot"
  local dot_cache="$CCH_STATE_DIR/dot_cache"
  local combo_cache="$dot_cache/combos"
  mkdir -p "$combo_cache"

  # DOT sources in priority order (higher priority = later, overwrites earlier)
  local dot_sources=("$CCH_ROOT/.dance-of-tal" "$dot_dir")
  local entry_count=0

  for src in "${dot_sources[@]}"; do
    [[ ! -d "$src" ]] && continue

    # Support both "combo" (singular) and "combos" (plural) directories
    local combo_dir=""
    if [[ -d "$src/combos" ]]; then
      combo_dir="$src/combos"
    elif [[ -d "$src/combo" ]]; then
      combo_dir="$src/combo"
    fi

    if [[ -n "$combo_dir" ]]; then
      # Copy entries to cache (later sources overwrite earlier = higher priority)
      local count
      count="$(find "$combo_dir" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
      if [[ "$count" -gt 0 ]]; then
        cp "$combo_dir"/* "$combo_cache/" 2>/dev/null || true
        entry_count=$((entry_count + count))
      fi
    fi

    # Copy combo.lock if present
    if [[ -f "$src/combo.lock" ]]; then
      cp "$src/combo.lock" "$dot_cache/combo.lock" 2>/dev/null || true
    fi
  done

  # Success = actual entries exist in cache AND cache is synced
  local cached_entries
  cached_entries="$(find "$combo_cache" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"

  if [[ "$cached_entries" -gt 0 && "$entry_count" -gt 0 ]]; then
    write_state "dot_compiled" "true"
    write_state "dot_compiled_at" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "[cch] DOT compiled: $cached_entries entries from local sources"
  elif [[ "$cached_entries" -gt 0 ]]; then
    write_state "dot_compiled" "cache"
    echo "[cch] DOT using cached combos ($cached_entries entries, sources unavailable)"
  else
    write_state "dot_compiled" "false"
    echo "[cch] WARN: No DOT combo entries found and no cache available"
  fi
}

dot_status() {
  local enabled compiled compiled_at
  enabled="$(read_state dot_enabled)"
  compiled="$(read_state dot_compiled)"
  compiled_at="$(read_state dot_compiled_at)"

  echo "=== DOT Experiment Status ==="
  echo "Enabled:     ${enabled:-false}"
  echo "Compiled:    ${compiled:-false}"
  if [[ -n "$compiled_at" ]]; then
    echo "Compiled at: $compiled_at"
  fi

  # Show KPI summary if available
  local kpi_file="$CCH_STATE_DIR/dot_kpi.json"
  if [[ -f "$kpi_file" ]]; then
    echo ""
    echo "=== KPI Metrics ==="
    cat "$kpi_file"
  fi
}

# --- KPI Measurement (JSONL: .claude/cch/metrics/dot-poc.jsonl) ---

METRICS_FILE="$CCH_STATE_DIR/metrics/dot-poc.jsonl"

cmd_kpi() {
  local action="${1:-show}"

  case "$action" in
    record)
      kpi_record "${@:2}"
      ;;
    show)
      kpi_show
      ;;
    reset)
      rm -f "$METRICS_FILE"
      echo "[cch] KPI data reset"
      ;;
    *)
      echo "[cch] Usage: cch kpi [record|show|reset]"
      ;;
  esac
}

kpi_record() {
  local metric="${1:-}" value="${2:-}"

  if [[ -z "$metric" || -z "$value" ]]; then
    echo "[cch] Usage: cch kpi record <metric> <value>"
    return 1
  fi

  case "$metric" in
    token_usage|mode_switch_latency|prompt_conflict|quality_regression|kill_switch) ;;
    *)
      echo "[cch] Unknown metric: $metric"
      echo "[cch] Valid: token_usage, mode_switch_latency, prompt_conflict, quality_regression, kill_switch"
      return 1
      ;;
  esac

  mkdir -p "$(dirname "$METRICS_FILE")"

  local ts mode
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mode="$(read_state mode)"

  echo "{\"ts\":\"$ts\",\"metric\":\"$metric\",\"value\":\"$value\",\"mode\":\"${mode:-}\"}" >> "$METRICS_FILE"
  echo "[cch] KPI recorded: $metric=$value"

  # Kill switch auto-check
  if [[ "$metric" == "quality_regression" ]]; then
    local regression_count
    regression_count="$(grep -c '"metric":"quality_regression"' "$METRICS_FILE" 2>/dev/null)" || regression_count=0
    if [[ "$regression_count" -ge 2 ]]; then
      echo "[cch] *** KILL SWITCH: quality_regression >= 2 ***"
      kpi_record "kill_switch" "quality_regression_threshold"
    fi
  fi
}

kpi_show() {
  echo "=== DOT PoC KPI Dashboard ==="

  if [[ ! -f "$METRICS_FILE" ]]; then
    echo "  No data. File: metrics/dot-poc.jsonl"
    return 0
  fi

  echo "  Source: $METRICS_FILE"
  echo ""

  # Token usage
  local token_count
  token_count="$(grep -c '"metric":"token_usage"' "$METRICS_FILE" 2>/dev/null)" || token_count=0
  echo "--- Token Usage (target: 20%+ reduction) ---"
  echo "  Samples: $token_count"
  if [[ "$token_count" -gt 0 ]]; then
    grep '"metric":"token_usage"' "$METRICS_FILE" 2>/dev/null | tail -3 | while read -r line; do
      local ts val
      ts="$(echo "$line" | sed 's/.*"ts":"\([^"]*\)".*/\1/')"
      val="$(echo "$line" | sed 's/.*"value":"\([^"]*\)".*/\1/')"
      echo "  $ts: $val"
    done
  fi

  # Mode switch latency
  echo ""
  local latency_count
  latency_count="$(grep -c '"metric":"mode_switch_latency"' "$METRICS_FILE" 2>/dev/null)" || latency_count=0
  echo "--- Mode Switch Latency (target: < 1000ms) ---"
  echo "  Samples: $latency_count"
  if [[ "$latency_count" -gt 0 ]]; then
    grep '"metric":"mode_switch_latency"' "$METRICS_FILE" 2>/dev/null | tail -3 | while read -r line; do
      local ts val
      ts="$(echo "$line" | sed 's/.*"ts":"\([^"]*\)".*/\1/')"
      val="$(echo "$line" | sed 's/.*"value":"\([^"]*\)".*/\1/')"
      echo "  $ts: ${val}ms"
    done
  fi

  # Prompt conflicts
  echo ""
  local conflict_count
  conflict_count="$(grep -c '"metric":"prompt_conflict"' "$METRICS_FILE" 2>/dev/null)" || conflict_count=0
  echo "--- Prompt Conflicts (target: < 1/week) ---"
  echo "  Total: $conflict_count"

  # Quality regressions (kill switch)
  echo ""
  local regression_count
  regression_count="$(grep -c '"metric":"quality_regression"' "$METRICS_FILE" 2>/dev/null)" || regression_count=0
  echo "--- Quality Regressions (kill switch: 2+) ---"
  echo "  Total: $regression_count"
  if [[ "$regression_count" -ge 2 ]]; then
    echo "  *** KILL SWITCH TRIGGERED ***"
  fi
}

_do_update() {
  local action="${1:-check}"

  case "$action" in
    check)
      update_check
      ;;
    apply)
      update_apply
      ;;
    rollback)
      shift
      update_rollback "$@"
      ;;
    history)
      update_history
      ;;
    *)
      echo "[cch] Usage: cch update [check|apply|rollback|history]"
      ;;
  esac
}

cmd_update() {
  if type lock_run &>/dev/null; then
    lock_run "update" _do_update "$@"
  else
    _do_update "$@"
  fi
}

update_check() {
  echo "[cch] Checking for updates..."
  echo "[cch] Current version: $CCH_VERSION"

  # Pin verification: compare release.lock checksums
  local lock_file="$CCH_ROOT/manifests/release.lock"
  if [[ -f "$lock_file" ]]; then
    echo "[cch] Release lock: present"

    # Verify current files against lock
    local mismatches=0
    local lock_reasons=()
    while IFS='  ' read -r expected_hash file_path; do
      [[ "$expected_hash" == "#"* || -z "$expected_hash" ]] && continue
      local actual_file="$CCH_ROOT/$file_path"
      if [[ -f "$actual_file" ]]; then
        local actual_hash
        actual_hash="$(shasum -a 256 "$actual_file" | awk '{print $1}')"
        if [[ "$expected_hash" != "$actual_hash" ]]; then
          echo "[cch] CHANGED: $file_path"
          lock_reasons+=("${RC_LOCK_CHANGED}:${file_path}")
          mismatches=$((mismatches + 1))
        fi
      else
        echo "[cch] MISSING: $file_path"
        lock_reasons+=("${RC_LOCK_MISSING}:${file_path}")
        mismatches=$((mismatches + 1))
      fi
    done < "$lock_file"

    if [[ $mismatches -eq 0 ]]; then
      echo "[cch] Pin verification: PASS (all files match)"
      # Do not override resolve-based health; just log the check result
    else
      echo "[cch] Pin verification: $mismatches file(s) changed"
      # Write integrity failure reason codes into health state
      write_health "Degraded" "${lock_reasons[@]}"
    fi
  else
    echo "[cch] Release lock: not found (development mode)"
  fi
}

update_apply() {
  echo "[cch] Creating rollback point..."

  # Create rollback point before applying updates
  local rollback_dir="$CCH_STATE_DIR/rollbacks"
  local rollback_id
  rollback_id="$(date -u +%Y%m%d%H%M%S)"
  local rollback_path="$rollback_dir/$rollback_id"
  mkdir -p "$rollback_path"

  # Save current state
  cp -R "$CCH_STATE_DIR/mode" "$rollback_path/" 2>/dev/null || true
  cp -R "$CCH_STATE_DIR/health" "$rollback_path/" 2>/dev/null || true
  cp -R "$CCH_STATE_DIR/dot_enabled" "$rollback_path/" 2>/dev/null || true

  # Save current version
  echo "$CCH_VERSION" > "$rollback_path/version"

  # Save release lock if exists
  if [[ -f "$CCH_ROOT/manifests/release.lock" ]]; then
    cp "$CCH_ROOT/manifests/release.lock" "$rollback_path/release.lock"
  fi

  echo "[cch] Rollback point created: $rollback_id"
  echo "[cch] To rollback: cch update rollback $rollback_id"
  echo ""
  echo "[cch] Update apply: no remote updates available (local-only mode)"
  echo "[cch] Run 'cch update check' to verify pin integrity."
}

update_rollback() {
  local rollback_id="${1:-}"
  local rollback_dir="$CCH_STATE_DIR/rollbacks"

  if [[ -z "$rollback_id" ]]; then
    echo "[cch] Usage: cch update rollback <rollback_id>"
    echo "[cch] Available rollback points:"
    if [[ -d "$rollback_dir" ]]; then
      ls -1 "$rollback_dir" 2>/dev/null | while read -r id; do
        local ver="unknown"
        if [[ -f "$rollback_dir/$id/version" ]]; then
          ver="$(cat "$rollback_dir/$id/version")"
        fi
        echo "  $id (v$ver)"
      done
    else
      echo "  (none)"
    fi
    return 0
  fi

  local rollback_path="$rollback_dir/$rollback_id"
  if [[ ! -d "$rollback_path" ]]; then
    echo "[cch] ERROR: Rollback point not found: $rollback_id"
    return 1
  fi

  echo "[cch] Rolling back to: $rollback_id"

  # Restore state files
  local restored=0
  for state_file in mode health dot_enabled health_reason; do
    if [[ -f "$rollback_path/$state_file" ]]; then
      cp "$rollback_path/$state_file" "$CCH_STATE_DIR/$state_file"
      restored=$((restored + 1))
    fi
  done

  if [[ $restored -eq 0 ]]; then
    echo "[cch] WARNING: No state files found in rollback point"
    return 1
  fi

  # Post-restore verification (3 steps)
  local verify_ok=true

  # Step 1: Verify state files exist
  if [[ ! -f "$CCH_STATE_DIR/mode" ]]; then
    echo "[cch] VERIFY FAIL: mode file missing after restore"
    verify_ok=false
  fi
  if [[ ! -f "$CCH_STATE_DIR/health" ]]; then
    echo "[cch] VERIFY FAIL: health file missing after restore"
    verify_ok=false
  fi

  # Step 2: Validate mode value
  if [[ -f "$CCH_STATE_DIR/mode" ]]; then
    local restored_mode
    restored_mode="$(cat "$CCH_STATE_DIR/mode" 2>/dev/null)"
    local valid_modes=("plan" "code" "tool" "swarm")
    local mode_valid=false
    for m in "${valid_modes[@]}"; do
      [[ "$restored_mode" == "$m" ]] && mode_valid=true
    done
    if [[ "$mode_valid" == "false" ]]; then
      echo "[cch] VERIFY FAIL: invalid mode '$restored_mode'"
      verify_ok=false
    fi
  fi

  # Step 3: Verify resolve can run
  if [[ "$verify_ok" == "true" ]]; then
    if cmd_resolve "$(cat "$CCH_STATE_DIR/mode" 2>/dev/null)" >/dev/null 2>&1; then
      echo "[cch] Rollback complete. Verification: PASS ($restored files restored)"
      return 0
    else
      echo "[cch] WARNING: Rollback applied but resolve returned errors"
      echo "[cch] Run 'cch doctor' to diagnose."
      return 0
    fi
  else
    echo "[cch] Rollback applied with verification warnings."
    echo "[cch] Run 'cch doctor' to diagnose."
    return 1
  fi
}

update_history() {
  local rollback_dir="$CCH_STATE_DIR/rollbacks"
  echo "=== Update History ==="
  if [[ -d "$rollback_dir" ]]; then
    ls -1 "$rollback_dir" 2>/dev/null | while read -r id; do
      local ver="unknown"
      if [[ -f "$rollback_dir/$id/version" ]]; then
        ver="$(cat "$rollback_dir/$id/version")"
      fi
      echo "  $id  v$ver"
    done
  else
    echo "  No rollback points recorded."
  fi
}

cmd_release() {
  local version="${1:-}"

  if [[ -z "$version" ]]; then
    echo "[cch] Usage: cch release <version>"
    echo "[cch] Example: cch release 0.2.0"
    return 1
  fi

  # Validate semver format
  if ! [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "[cch] ERROR: Invalid version format '$version'. Use semver: X.Y.Z"
    return 1
  fi

  local tag="v${version}"

  # --- Stage 1: Pre-flight checks ---
  echo "[cch] === Stage 1/5: Pre-flight ==="

  if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    echo "[cch] ERROR: Uncommitted changes detected. Commit or stash first."
    return 1
  fi

  if git rev-parse "$tag" &>/dev/null; then
    echo "[cch] ERROR: Tag '$tag' already exists."
    return 1
  fi

  echo "[cch] Pre-flight: OK"

  # --- Stage 2: Version bump ---
  echo "[cch] === Stage 2/5: Version bump ==="

  local old_version="$CCH_VERSION"
  local cch_file="$CCH_ROOT/bin/cch"
  local plugin_file="$CCH_ROOT/.claude-plugin/plugin.json"

  # Bump CCH_VERSION in bin/cch
  sed -i.bak "s/^CCH_VERSION=\"${old_version}\"/CCH_VERSION=\"${version}\"/" "$cch_file" && rm -f "${cch_file}.bak"

  # Bump version in plugin.json
  if [[ -f "$plugin_file" ]]; then
    sed -i.bak "s/\"version\": \"${old_version}\"/\"version\": \"${version}\"/" "$plugin_file" && rm -f "${plugin_file}.bak"
  fi

  # Verify bump succeeded
  if ! grep -q "CCH_VERSION=\"${version}\"" "$cch_file"; then
    echo "[cch] ERROR: Version bump failed in bin/cch. Rolling back..."
    git checkout -- "$cch_file" "$plugin_file" 2>/dev/null
    return 1
  fi

  echo "[cch] Version: $old_version -> $version"

  # --- Stage 3: Build bundle ---
  echo "[cch] === Stage 3/5: Build bundle ==="

  local build_script="$CCH_ROOT/scripts/build-release.sh"
  if [[ ! -f "$build_script" ]]; then
    echo "[cch] ERROR: Build script not found: scripts/build-release.sh"
    echo "[cch] Rolling back version bump..."
    git checkout -- "$cch_file" "$plugin_file" 2>/dev/null
    return 1
  fi

  if ! bash "$build_script"; then
    echo "[cch] ERROR: Build failed. Rolling back version bump..."
    git checkout -- "$cch_file" "$plugin_file" 2>/dev/null
    return 1
  fi

  echo "[cch] Build: OK"

  # --- Stage 4: Git commit + tag ---
  echo "[cch] === Stage 4/5: Git commit + tag ==="

  git add "$cch_file" "$plugin_file"
  git commit -m "$(cat <<EOF
release: v${version}

Co-Authored-By: Claude <noreply@anthropic.com>
EOF
  )"

  git tag -a "$tag" -m "Release ${version}"

  echo "[cch] Committed and tagged: $tag"

  # --- Stage 5: Cache sync ---
  echo "[cch] === Stage 5/5: Cache sync ==="

  if ! cmd_sync skills 2>/dev/null; then
    echo "[cch] WARN: Cache sync failed (non-fatal). Run 'cch sync' manually."
  else
    echo "[cch] Cache sync: OK"
  fi

  # --- Summary ---
  echo ""
  echo "[cch] === Release Complete ==="
  echo "[cch] Version: $version"
  echo "[cch] Tag:     $tag"
  echo "[cch] Bundle:  dist/claude-code-harness-${version}/"
  echo ""
  echo "[cch] Next steps:"
  echo "[cch]   git push origin $(git rev-parse --abbrev-ref HEAD) --tags"
}

cmd_sync() {
  local action="${1:-all}"
  shift || true

  case "$action" in
    skills) sync_skills "$@" ;;
    bin)    sync_bin ;;
    all)    sync_bin; sync_skills "$@" ;;
    *)
      echo "[cch] Usage: cch sync [all|skills|bin] [source-dir]"
      echo ""
      echo "  all     Sync binary + skills (default)"
      echo "  skills  Sync skills only from current project"
      echo "  bin     Sync cch binary to plugin cache"
      ;;
  esac
}

# Resolve plugin cache path from installed_plugins.json
_resolve_cache_path() {
  local installed_plugins="$HOME/.claude/plugins/installed_plugins.json"

  if [[ ! -f "$installed_plugins" ]]; then
    echo "[cch] ERROR: installed_plugins.json not found. Plugin not installed?" >&2
    return 1
  fi

  local cache_path
  cache_path="$(sed -n 's/.*"installPath"[[:space:]]*:[[:space:]]*"\([^"]*claude-code-harness[^"]*\)".*/\1/p' "$installed_plugins" | head -1)"

  if [[ -z "$cache_path" || ! -d "$cache_path" ]]; then
    echo "[cch] ERROR: Plugin cache path not found or invalid: ${cache_path:-<empty>}" >&2
    return 1
  fi

  echo "$cache_path"
}

sync_bin() {
  local src_bin="$PWD/bin/cch"
  local src_lib="$PWD/bin/lib"

  if [[ ! -f "$src_bin" ]]; then
    echo "[cch] SKIP bin: No bin/cch in $PWD (not a CCH source repo)"
    return 0
  fi

  local cache_path
  cache_path="$(_resolve_cache_path)" || return 1

  local dst_bin="$cache_path/bin/cch"
  local dst_lib="$cache_path/bin/lib"

  local bin_changed=false

  # Sync binary
  local src_hash dst_hash
  src_hash="$(shasum -a 256 "$src_bin" 2>/dev/null | awk '{print $1}')"
  dst_hash="$(shasum -a 256 "$dst_bin" 2>/dev/null | awk '{print $1}')"

  if [[ "$src_hash" != "$dst_hash" ]]; then
    cp "$src_bin" "$dst_bin"
    chmod +x "$dst_bin"
    echo "[cch] Binary updated."
    bin_changed=true
  fi

  # Sync lib/ directory if present
  if [[ -d "$src_lib" ]]; then
    mkdir -p "$dst_lib"
    local lib_updated=0
    for src_file in "$src_lib"/*; do
      [[ ! -f "$src_file" ]] && continue
      local fname
      fname="$(basename "$src_file")"
      local sf_hash df_hash
      sf_hash="$(shasum -a 256 "$src_file" 2>/dev/null | awk '{print $1}')"
      df_hash="$(shasum -a 256 "$dst_lib/$fname" 2>/dev/null | awk '{print $1}')"
      if [[ "$sf_hash" != "$df_hash" ]]; then
        cp "$src_file" "$dst_lib/$fname"
        lib_updated=$((lib_updated + 1))
      fi
    done
    if [[ "$lib_updated" -gt 0 ]]; then
      echo "[cch] lib/ updated ($lib_updated files)."
      bin_changed=true
    fi
  fi

  # Sync scripts/ directory if present
  local src_scripts="$PWD/scripts"
  if [[ -d "$src_scripts" ]]; then
    local dst_scripts="$cache_path/scripts"
    mkdir -p "$dst_scripts"
    local scripts_updated=0
    for src_file in "$src_scripts"/*.sh "$src_scripts"/*.mjs; do
      [[ ! -f "$src_file" ]] && continue
      local fname
      fname="$(basename "$src_file")"
      local sf_hash df_hash
      sf_hash="$(shasum -a 256 "$src_file" 2>/dev/null | awk '{print $1}')"
      df_hash="$(shasum -a 256 "$dst_scripts/$fname" 2>/dev/null | awk '{print $1}')"
      if [[ "$sf_hash" != "$df_hash" ]]; then
        cp "$src_file" "$dst_scripts/$fname"
        scripts_updated=$((scripts_updated + 1))
      fi
    done
    if [[ "$scripts_updated" -gt 0 ]]; then
      echo "[cch] scripts/ updated ($scripts_updated files)."
      bin_changed=true
    fi
  fi

  # Sync hooks/hooks.json if present
  local src_hooks="$PWD/hooks/hooks.json"
  if [[ -f "$src_hooks" ]]; then
    local dst_hooks="$cache_path/hooks/hooks.json"
    local sh_hash dh_hash
    sh_hash="$(shasum -a 256 "$src_hooks" 2>/dev/null | awk '{print $1}')"
    dh_hash="$(shasum -a 256 "$dst_hooks" 2>/dev/null | awk '{print $1}')"
    if [[ "$sh_hash" != "$dh_hash" ]]; then
      cp "$src_hooks" "$dst_hooks"
      echo "[cch] hooks.json updated."
      bin_changed=true
    fi
  fi

  if [[ "$bin_changed" == "false" ]]; then
    echo "[cch] Core already up-to-date."
  fi
}

sync_skills() {
  local src_skills="${1:-$PWD/skills}"
  local project_id
  project_id="$(basename "$PWD")"

  if [[ ! -d "$src_skills" ]]; then
    echo "[cch] ERROR: Source skills directory not found: $src_skills"
    return 1
  fi

  local cache_path
  cache_path="$(_resolve_cache_path)" || return 1

  local dst_skills="$cache_path/skills"

  echo "[cch] Syncing skills..."
  echo "[cch]   Project: $project_id"
  echo "[cch]   Source:  $src_skills"
  echo "[cch]   Target:  $dst_skills"
  echo ""

  mkdir -p "$dst_skills"

  local added=0 updated=0 unchanged=0

  for skill_dir in "$src_skills"/*/; do
    [[ ! -d "$skill_dir" ]] && continue
    local skill_name
    skill_name="$(basename "$skill_dir")"
    local dst_dir="$dst_skills/$skill_name"

    if [[ ! -d "$dst_dir" ]]; then
      cp -R "$skill_dir" "$dst_dir"
      echo "$project_id" > "$dst_dir/.sync-owner"
      echo "  [ADD] $skill_name"
      added=$((added + 1))
    else
      # Compare SKILL.md checksums
      local src_hash dst_hash
      src_hash="$(shasum -a 256 "$skill_dir/SKILL.md" 2>/dev/null | awk '{print $1}')"
      dst_hash="$(shasum -a 256 "$dst_dir/SKILL.md" 2>/dev/null | awk '{print $1}')"
      if [[ "$src_hash" != "$dst_hash" ]]; then
        rm -rf "$dst_dir"
        cp -R "$skill_dir" "$dst_dir"
        echo "$project_id" > "$dst_dir/.sync-owner"
        echo "  [UPD] $skill_name"
        updated=$((updated + 1))
      else
        # Ensure ownership is tracked even for unchanged skills
        echo "$project_id" > "$dst_dir/.sync-owner"
        unchanged=$((unchanged + 1))
      fi
    fi
  done

  # Remove skills owned by THIS project that no longer exist in source
  local removed=0
  for cached_dir in "$dst_skills"/*/; do
    [[ ! -d "$cached_dir" ]] && continue
    local cached_name owner
    cached_name="$(basename "$cached_dir")"
    owner="$(cat "$cached_dir/.sync-owner" 2>/dev/null || echo "")"

    # Only delete if owned by current project (or unowned for backward compat)
    if [[ "$owner" == "$project_id" || -z "$owner" ]] && [[ ! -d "$src_skills/$cached_name" ]]; then
      rm -rf "$cached_dir"
      echo "  [DEL] $cached_name"
      removed=$((removed + 1))
    fi
  done

  echo ""
  echo "[cch] Sync complete: +${added} added, ~${updated} updated, -${removed} removed, ${unchanged} unchanged"
  if [[ $((added + updated + removed)) -gt 0 ]]; then
    echo "[cch] Restart Claude Code session to apply changes."
  else
    echo "[cch] No changes needed."
  fi
}

cmd_version() {
  echo "cch $CCH_VERSION"
}

cmd_help() {
  cat <<EOF
cch - Claude Code Harness Engine v${CCH_VERSION}

Usage: cch <command> [options]

Commands:
  setup [--no-fetch] Initialize CCH environment (auto-installs sources)
  mode [<mode>]      Get/set mode (plan|code|tool|swarm)
  doctor [--summary] Show health status
  resolve [<mode>]   Resolve capabilities for mode
  sources [status|install|update]  External source management
  log [show|tail]    Execution log viewer
  release <version>  Create versioned release bundle with tag
  sync [all|skills|bin]  Sync binary + skills to plugin cache
  dot [on|off|status] Toggle DOT experiment (code mode only)
  kpi [record|show|reset] DOT PoC KPI measurement (JSONL)
  todo               Alias for 'beads list' (legacy compatibility)
  beads [cmd]        Beads task tracking (create|list|show|ready|close|dep)
  update             Check and apply updates
  version            Show version
  help               Show this help
EOF
}

# --- Main ---

main() {
  local cmd="${1:-help}"
  shift || true

  # Auto-record execution log (skip log/help/version to avoid recursion)
  local _cch_log_enabled=false
  case "$cmd" in
    log|help|--help|-h|version) ;;
    *)
      if [[ -n "${CCH_LIB_DIR:-}" ]] && type log_start &>/dev/null; then
        log_start "_global" "$cmd $*"
        _cch_log_enabled=true
      fi
      ;;
  esac

  local _cch_exit_code=0
  case "$cmd" in
    setup)           cmd_setup "$@" || _cch_exit_code=$? ;;
    mode)            cmd_mode "$@" || _cch_exit_code=$? ;;
    status)          cmd_status "$@" || _cch_exit_code=$? ;;
    doctor)          cmd_doctor "$@" || _cch_exit_code=$? ;;
    resolve)         cmd_resolve "$@" || _cch_exit_code=$? ;;
    sources)         cmd_sources "$@" || _cch_exit_code=$? ;;
    branch)          cmd_branch "$@" || _cch_exit_code=$? ;;
    log)             cmd_log "$@" || _cch_exit_code=$? ;;
    dot)             cmd_dot "$@" || _cch_exit_code=$? ;;
    release)         cmd_release "$@" || _cch_exit_code=$? ;;
    sync)            cmd_sync "$@" || _cch_exit_code=$? ;;
    kpi)             cmd_kpi "$@" || _cch_exit_code=$? ;;
    kpi-dashboard)   cmd_kpi_dashboard "$@" || _cch_exit_code=$? ;;
    dot-report)      cmd_dot_report "$@" || _cch_exit_code=$? ;;
    todo)            cmd_beads list "$@" || _cch_exit_code=$? ;;
    beads)           cmd_beads "$@" || _cch_exit_code=$? ;;
    arch)            cmd_arch "$@" || _cch_exit_code=$? ;;
    update)          cmd_update "$@" || _cch_exit_code=$? ;;
    version)         cmd_version || _cch_exit_code=$? ;;
    help|--help|-h)  cmd_help ;;
    *)
      echo "[cch] Unknown command: $cmd"
      cmd_help
      _cch_exit_code=1
      ;;
  esac

  # Record end with result
  if [[ "$_cch_log_enabled" == "true" ]] && type log_end &>/dev/null; then
    if [[ "$_cch_exit_code" -eq 0 ]]; then
      log_end "ok"
    else
      log_end "error" "exit_code" "command failed with exit code $_cch_exit_code"
    fi
  fi

  return "$_cch_exit_code"
}

main "$@"
