#!/usr/bin/env bash
# cch - Claude Code Harness internal engine
# Usage: cch <command> [options]

set -euo pipefail

CCH_VERSION="0.2.0"
CCH_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CCH_STATE_DIR="${CCH_STATE_DIR:-.claude/cch}"
CCH_LIB_DIR="$CCH_ROOT/bin/lib"

# --- Load modules ---
# shellcheck source=lib/log.sh
[[ -f "$CCH_LIB_DIR/log.sh" ]] && source "$CCH_LIB_DIR/log.sh"
# shellcheck source=lib/branch.sh
[[ -f "$CCH_LIB_DIR/branch.sh" ]] && source "$CCH_LIB_DIR/branch.sh"
# shellcheck source=lib/lock.sh
[[ -f "$CCH_LIB_DIR/lock.sh" ]] && source "$CCH_LIB_DIR/lock.sh"
# shellcheck source=lib/skill.sh
[[ -f "$CCH_LIB_DIR/skill.sh" ]] && source "$CCH_LIB_DIR/skill.sh"

# --- State helpers ---

ensure_state_dir() {
  mkdir -p "$CCH_STATE_DIR"
}

# Ensure all namespaced state directories exist per Architecture spec:
#   .claude/cch/
#   ├── init/           # cch-init state (scan-result, progress, mode)
#   ├── state/          # runtime state (execution logs)
#   │   └── logs/       # execution logs
#   └── execution-plan.json  # current execution plan
_ensure_state_dirs() {
  mkdir -p "$CCH_STATE_DIR/init"
  mkdir -p "$CCH_STATE_DIR/state/logs"
}

read_state() {
  local key="$1"
  local file="$CCH_STATE_DIR/$key"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo ""
  fi
}

write_state() {
  local key="$1"
  local value="$2"
  ensure_state_dir
  echo "$value" > "$CCH_STATE_DIR/$key"
}

# --- Standard Reason Codes ---
# Format: RC_<CATEGORY>:<detail>
# Used by: cmd_setup, cmd_status
RC_ALL_OK="RC_ALL_OK"                           # Healthy: all checks passed
RC_MISSING_DIR="RC_MISSING_DIR"                 # Blocked: required directory missing (append :dirs)

# Write health state with mandatory reason_code
# Usage: write_health <status> <reason_code1> [reason_code2] ...
write_health() {
  local status="$1"; shift
  local codes=("$@")
  write_state "health" "$status"
  if [[ ${#codes[@]} -gt 0 ]]; then
    write_state "health_reason" "$(IFS=','; echo "${codes[*]}")"
  else
    write_state "health_reason" "$RC_ALL_OK"
  fi
}

# Read health reason codes as array (sets HEALTH_REASON_CODES)
# Usage: read_health_reasons; for rc in "${HEALTH_REASON_CODES[@]}"; do ...
read_health_reasons() {
  local raw
  raw="$(read_state health_reason)"
  HEALTH_REASON_CODES=()
  if [[ -n "$raw" ]]; then
    IFS=',' read -ra HEALTH_REASON_CODES <<< "$raw"
  fi
}

# --- Tier System ---
# Tier 0: CCH core only

_calculate_tier() {
  local tier=0

  # Check any installed plugin (generic detection)
  local cache_dir="$HOME/.claude/plugins/cache"
  if [[ -d "$cache_dir" ]]; then
    local plugin_count
    plugin_count=$(find "$cache_dir" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$plugin_count" -gt 0 ]]; then
      tier=1
    fi
  fi

  # Check additional extensions (MCP servers, etc.)
  if [[ $tier -ge 1 ]]; then
    local mcp_config="$HOME/.claude/mcp.json"
    if [[ -f "$mcp_config" ]] && command -v node &>/dev/null; then
      local server_count
      server_count=$(node -e "try{const c=JSON.parse(require('fs').readFileSync('$mcp_config','utf8'));console.log(Object.keys(c.mcpServers||{}).length)}catch{console.log(0)}" 2>/dev/null || echo "0")
      if [[ "$server_count" -gt 0 ]]; then
        tier=2
      fi
    fi
  fi

  echo "$tier"
}

# --- Cleanup (LW: replaces full GC Engine) ---

_cleanup_dir() {
  local dir="$1" pattern="$2" age_flag="$3" age_val="$4"
  if [[ ! -d "$dir" ]]; then echo "0"; return 0; fi
  local count
  count=$(find "$dir" -name "$pattern" "$age_flag" "$age_val" 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$count" -gt 0 ]]; then
    find "$dir" -name "$pattern" "$age_flag" "$age_val" -delete 2>/dev/null
  fi
  echo "$count"
}

_cleanup_stale_files() {
  local cleaned=0
  cleaned=$((cleaned + $(_cleanup_dir "$CCH_STATE_DIR/sessions" '*.json'  -mtime +7)))
  cleaned=$((cleaned + $(_cleanup_dir "$CCH_STATE_DIR/runs"     '*.jsonl' -mtime +7)))
  cleaned=$((cleaned + $(_cleanup_dir "$CCH_STATE_DIR/locks"    '*.lock'  -mmin  +60)))

  if [[ "$cleaned" -gt 0 ]]; then
    echo "[cch] Cleaned $cleaned stale files"
  fi
}

# --- Commands ---

_migrate_v1_to_v2() {
  local migrated=0

  # Remove v1 state files that no longer exist in v2
  for old_key in dot_enabled vendor_status resolved_hash; do
    if [[ -f "$CCH_STATE_DIR/$old_key" ]]; then
      rm -f "$CCH_STATE_DIR/$old_key"
      migrated=$((migrated + 1))
    fi
  done

  # Remove v1 .resolved/ directory
  if [[ -d "$CCH_STATE_DIR/.resolved" ]]; then
    rm -rf "$CCH_STATE_DIR/.resolved"
    migrated=$((migrated + 1))
  fi

  # Migrate v1 modes (tool/swarm) to v2 default (code)
  local current_mode
  current_mode="$(read_state mode)"
  if [[ "$current_mode" == "tool" || "$current_mode" == "swarm" ]]; then
    write_state "mode" "code"
    echo "[cch] Migrated mode: $current_mode -> code (v2)"
    migrated=$((migrated + 1))
  fi

  if [[ "$migrated" -gt 0 ]]; then
    echo "[cch] v1→v2 migration: $migrated items cleaned up"
  fi
}

cmd_setup() {
  echo "[cch] Setting up Claude Code Harness v${CCH_VERSION}..."
  ensure_state_dir
  _ensure_state_dirs

  # v1→v2 migration (idempotent)
  _migrate_v1_to_v2

  # Check required directories
  local missing=()
  for dir in profiles manifests; do
    if [[ ! -d "$CCH_ROOT/$dir" ]]; then
      missing+=("$dir")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "[cch] ERROR: Missing directories: ${missing[*]}"
    write_health "Blocked" "${RC_MISSING_DIR}:${missing[*]}"
    return 1
  fi

  # Check profiles (v2: plan and code only)
  local modes=("plan" "code")
  for mode in "${modes[@]}"; do
    if [[ ! -f "$CCH_ROOT/profiles/$mode.json" ]]; then
      echo "[cch] WARN: Missing profile for mode: $mode"
    fi
  done

  # Initialize default state
  local current_mode
  current_mode="$(read_state mode)"
  if [[ -z "$current_mode" ]]; then
    write_state "mode" "code"
    echo "[cch] Default mode set to: code"
  fi

  # Tier detection
  local tier
  tier="$(_calculate_tier)"
  write_state "tier" "$tier"
  echo "[cch] Tier detected: $tier"

  # Cleanup stale files (LW: GC Engine → single function)
  _cleanup_stale_files

  # Basic health check
  write_health "Healthy" "$RC_ALL_OK"

  echo ""
  echo "[cch] Setup complete. State dir: $CCH_STATE_DIR"
  echo "[cch] Run 'cch status' to check status."
}

cmd_mode() {
  local target_mode="${1:-}"
  local valid_modes=("plan" "code")

  if [[ -z "$target_mode" ]]; then
    local current
    current="$(read_state mode)"
    echo "[cch] Current mode: ${current:-not set}"
    return 0
  fi

  # Validate mode
  case "$target_mode" in
    plan|code) ;;
    *)
      echo "[cch] ERROR: Invalid mode '$target_mode'. Valid: ${valid_modes[*]}"
      return 1
      ;;
  esac

  # Check profile exists
  if [[ ! -f "$CCH_ROOT/profiles/$target_mode.json" ]]; then
    echo "[cch] ERROR: Profile not found: profiles/$target_mode.json"
    return 1
  fi

  local prev_mode
  prev_mode="$(read_state mode)"
  write_state "mode" "$target_mode"
  echo "[cch] Mode changed: ${prev_mode:-none} -> $target_mode"

  # Auto-create PLAN document when switching to plan mode
  if [[ "$target_mode" == "plan" ]]; then
    _auto_create_plan_doc
  fi
}

_auto_create_plan_doc() {
  local plans_dir="$CCH_ROOT/docs/plans"
  mkdir -p "$plans_dir"

  local today
  today="$(date -u +%Y-%m-%d)"

  # Find active bead for plan naming
  local work_id="general"
  local exec_plan="$CCH_STATE_DIR/execution-plan.json"
  if [[ -f "$exec_plan" ]]; then
    local bead_id
    bead_id="$(sed -n 's/.*"bead_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$exec_plan" | head -1)"
    if [[ -n "$bead_id" ]]; then
      work_id="$bead_id"
    fi
  fi

  local plan_file="$plans_dir/${today}-${work_id}.md"

  # Skip if document already exists
  if [[ -f "$plan_file" ]]; then
    echo "[cch] PLAN document exists: $(basename "$plan_file")"
    return 0
  fi

  # Generate template
  cat > "$plan_file" <<PLANEOF
# Plan: ${work_id}

> Created: ${today}
> Work Item: ${work_id}
> Status: draft

## Goal

<!-- What is the objective of this plan? -->

## Context

<!-- Current state, constraints, dependencies -->

## Approach

<!-- Step-by-step approach -->

### Phase 1

- [ ] Step 1

### Phase 2

- [ ] Step 2

## Risks

<!-- Known risks and mitigations -->

## Acceptance Criteria

- [ ] Criterion 1

## Notes

<!-- Additional notes -->
PLANEOF

  echo "[cch] PLAN document created: $(basename "$plan_file")"
}

cmd_status() {
  local output_json=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) output_json=true; shift ;;
      *) shift ;;
    esac
  done

  local mode health health_reason
  mode="$(read_state mode)"
  health="$(read_state health)"
  health_reason="$(read_state health_reason)"

  if [[ "$output_json" == "true" ]]; then
    status_json "$mode" "$health" "$health_reason"
    return 0
  fi

  local tier
  tier="$(read_state tier)"

  echo "=== CCH Status ==="
  echo "Version:     $CCH_VERSION"
  echo "Mode:        ${mode:-not set}"
  echo "Tier:        ${tier:-0}"
  echo "Health:      ${health:-Unknown}"

  # Branch info (only if branch module loaded)
  if type branch_base &>/dev/null; then
    local current_branch
    current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    echo "Branch:      ${current_branch:-detached}"
    local sf="$CCH_STATE_DIR/branches/$(branch_state_filename "$current_branch" 2>/dev/null).yaml"
    if [[ -f "$sf" ]]; then
      echo "Work-Item:   $(yaml_get "$sf" "work_id")"
    fi
  fi

  # Reason codes
  if [[ -n "$health_reason" && "$health_reason" != "$RC_ALL_OK" ]]; then
    echo ""
    echo "=== Reason Codes ==="
    read_health_reasons
    for rc in "${HEALTH_REASON_CODES[@]}"; do
      echo "  - $rc"
    done
  fi
}

status_json() {
  # Delegate JSON generation to Node.js (core.mjs)
  node "$CCH_ROOT/scripts/lib/core.mjs" status-json
}

cmd_version() {
  echo "cch $CCH_VERSION"
}

cmd_help() {
  cat <<EOF
cch - Claude Code Harness Engine v${CCH_VERSION}

Usage: cch <command> [options]

Commands:
  setup              Initialize CCH environment
  mode [<mode>]      Get/set mode (plan|code)
  status [--json]    Show health status
  branch [cmd]       Branch workflow management
  skill [cmd]        Skill management (list|info|search|sources|validate)
  log [show|tail]    Execution log viewer
  version            Show version
  help               Show this help
EOF
}

# --- Main ---

main() {
  local cmd="${1:-help}"
  shift || true

  # Auto-record execution log (skip log/help/version to avoid recursion)
  local _cch_log_enabled=false
  case "$cmd" in
    log|help|--help|-h|version) ;;
    *)
      if [[ -n "${CCH_LIB_DIR:-}" ]] && type log_start &>/dev/null; then
        log_start "_global" "$cmd $*"
        _cch_log_enabled=true
      fi
      ;;
  esac

  local _cch_exit_code=0
  case "$cmd" in
    setup)           cmd_setup "$@" || _cch_exit_code=$? ;;
    mode)            cmd_mode "$@" || _cch_exit_code=$? ;;
    status)          cmd_status "$@" || _cch_exit_code=$? ;;
    branch)          cmd_branch "$@" || _cch_exit_code=$? ;;
    log)             cmd_log "$@" || _cch_exit_code=$? ;;
    skill)           cmd_skill "$@" || _cch_exit_code=$? ;;
    version)         cmd_version || _cch_exit_code=$? ;;
    help|--help|-h)  cmd_help ;;
    *)
      echo "[cch] Unknown command: $cmd"
      cmd_help
      _cch_exit_code=1
      ;;
  esac

  # Record end with result
  if [[ "$_cch_log_enabled" == "true" ]] && type log_end &>/dev/null; then
    if [[ "$_cch_exit_code" -eq 0 ]]; then
      log_end "ok"
    else
      log_end "error" "exit_code" "command failed with exit code $_cch_exit_code"
    fi
  fi

  return "$_cch_exit_code"
}

main "$@"
